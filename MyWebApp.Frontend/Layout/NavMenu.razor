        <section class="nav-section nav-section-last">
            <h6 class="nav-section-title">Administration</h6>
            <div class="nav-section-items">
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/users">
                        <span class="nav-link-title">Utilisateurs</span>
                        <span class="nav-link-sub">Accès et gestion de l'équipe</span>
                    </NavLink>
                </div>
            </div>
        </section>

