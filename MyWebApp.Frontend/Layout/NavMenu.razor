<div class="top-row navbar navbar-dark px-3">
    <div class="d-flex align-items-center gap-2">
        <img src="images/cap_logo.png"
             alt="Capgemini Logo"
             style="height:56px; width: auto;" />
    </div>

    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass nav-scrollable">
    <nav class="nav flex-column nav-menu-structured pt-2">

        <!-- Accueil -->
        <section class="nav-section">
            <div class="nav-section-items">
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="" Match="NavLinkMatch.All">
                        <span class="nav-link-title">Tableau de bord</span>
                        <span class="nav-link-sub">Vue d'ensemble et alertes</span>
                    </NavLink>
                </div>
            </div>
        </section>

        <!-- Pilotage projet -->
        <section class="nav-section">
            <h6 class="nav-section-title">Pilotage projet</h6>
            <div class="nav-section-items">
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/categories">
                        <span class="nav-link-title">Catégories</span>
                        <span class="nav-link-sub">Projets, échéances et regroupement</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/tasks">
                        <span class="nav-link-title">Tâches</span>
                        <span class="nav-link-sub">Actions à réaliser par l'équipe</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/reports">
                        <span class="nav-link-title">Rapports</span>
                        <span class="nav-link-sub">Indicateurs et synthèse</span>
                    </NavLink>
                </div>
            </div>
        </section>

        <!-- Livrables & documents -->
        <section class="nav-section">
            <h6 class="nav-section-title">Livrables &amp; documents</h6>
            <div class="nav-section-items">
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/deliverables">
                        <span class="nav-link-title">Chargement de fichiers</span>
                        <span class="nav-link-sub">Importer et analyser un livrable</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/deliverables-register">
                        <span class="nav-link-title">Fichiers enregistrés</span>
                        <span class="nav-link-sub">Registre des documents importés</span>
                    </NavLink>
                </div>
            </div>
        </section>

        <!-- Sources & synchronisation -->
        <section class="nav-section">
            <h6 class="nav-section-title">Sources &amp; synchronisation</h6>
            <div class="nav-section-items">
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/emails">
                        <span class="nav-link-title">Emails</span>
                        <span class="nav-link-sub">Extraction d'actions depuis Outlook</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link nav-link-stacked" href="/calendar">
                        <span class="nav-link-title">Calendrier</span>
                        <span class="nav-link-sub">Réunions, jalons et échéances</span>
                    </NavLink>
