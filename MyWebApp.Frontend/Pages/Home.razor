
@page "/"

@using MyWebApp.Frontend.Models
@using MyWebApp.Frontend.Services
@using TaskItem = MyWebApp.Frontend.Models.TaskItem

@inject AuthService AuthService
@inject NavigationManager Navigation
@inject TaskService TaskService
@inject DashboardService DashboardService
@inject HttpClient Http

<div class="container-fluid mt-4 dashboard-page">

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Chargement du tableau de bord…</p>
        </div>
    }
    else
    {
        <!-- En-tête -->
        <div class="dashboard-hero mb-4 d-flex flex-wrap justify-content-between align-items-start gap-3">
            <div>
                <h1 class="fw-bold mb-1 h2">Tableau de bord</h1>
                <p class="mb-0 text-white-50">
                    Vue d'ensemble claire — @DateTime.Now.ToString("dddd d MMMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))
                </p>
                <span class="badge bg-light text-dark mt-2">
                    Système : @dashboard.BackendStatus · @dashboard.Database
                </span>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-light btn-sm" @onclick="TriggerEmailSync" disabled="@isSyncing">
                    @(isSyncing ? "Sync…" : "📧 Sync Outlook")
                </button>
                <a class="btn btn-warning btn-sm" href="/ai">🤖 Analyse IA</a>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(syncMessage))
        {
            <div class="alert alert-info py-2 mb-4">@syncMessage</div>
        }

        <!-- KPI -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="card kpi-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="kpi-icon bg-primary bg-opacity-10 text-primary">📂</div>
                        <div>
                            <div class="kpi-value text-primary">@dashboard.TotalProjects</div>
                            <div class="text-muted small">Catégories / projets</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card kpi-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="kpi-icon bg-secondary bg-opacity-10 text-secondary">✅</div>
                        <div>
                            <div class="kpi-value">@dashboard.OpenTasks</div>
                            <div class="text-muted small">Tâches en cours</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card kpi-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="kpi-icon bg-warning bg-opacity-25 text-warning">⏰</div>
                        <div>
                            <div class="kpi-value text-warning">@dashboard.UrgentTasks</div>
                            <div class="text-muted small">Échéance ≤ 7 jours</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card kpi-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="kpi-icon bg-danger bg-opacity-10 text-danger">⚠️</div>
                        <div>
                            <div class="kpi-value text-danger">@dashboard.HighRiskCount</div>
                            <div class="text-muted small">Catégories à risque</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Accès rapide -->
        <div class="mb-4">
            <h5 class="fw-semibold mb-2">Accès rapide</h5>
            <div class="d-flex flex-wrap gap-2">
                <a href="/categories" class="btn btn-outline-primary quick-link">Catégories</a>
                <a href="/tasks" class="btn btn-outline-primary quick-link">Tâches</a>
                <a href="/deliverables" class="btn btn-outline-secondary quick-link">Chargement fichiers</a>
                <a href="/deliverables-register" class="btn btn-outline-secondary quick-link">Fichiers enregistrés</a>
                <a href="/emails" class="btn btn-outline-secondary quick-link">Emails</a>
                <a href="/calendar" class="btn btn-outline-secondary quick-link">Calendrier</a>
            </div>
        </div>

        <!-- Contenu principal -->
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-semibold mb-0">Prochaines échéances</h5>
                            <a href="/tasks" class="small link-primary">Voir tout →</a>
                        </div>

                        @if (upcomingTasks.Count == 0)
                        {
                            <div class="empty-state">
                                <span class="fs-4">🎉</span>
                                <p class="mb-0 mt-2">Aucune tâche en attente pour le moment.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var task in upcomingTasks)
                            {
                                var urgency = GetUrgency(task.Deadline);
                                <div class="task-row @urgency.CssClass">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <strong>@task.Title</strong>
                                            <div class="small text-muted">@GetStatusLabel(task.Status)</div>
                                        </div>
                                        <span class="badge @urgency.BadgeClass shrink-0">@urgency.Label</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-semibold mb-0">Derniers fichiers</h5>
                            <a href="/deliverables-register" class="small link-primary">Registre →</a>
                        </div>

                        @if (latestFiles.Count == 0)
                        {
                            <div class="empty-state py-4">
                                <p class="mb-0 small">Aucun fichier importé récemment.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var file in latestFiles)
                            {
                                <div class="file-row d-flex justify-content-between gap-2">
                                    <div class="text-truncate">
                                        <strong class="d-block text-truncate">@file.FileName</strong>
                                        <small class="text-muted">@file.ProjectName</small>
                                    </div>
                                    <small class="text-muted shrink-0">@file.UploadDate.ToString("dd/MM/yy")</small>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Popup : tâches proches de l'échéance -->
@if (showUrgentModal && urgentTasks.Count > 0)
{
    <div class="modal d-block urgent-modal" tabindex="-1" style="background-color: rgba(0,0,0,0.55); z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">⚠️ Attention — échéances proches</h5>
                    <button type="button" class="btn-close" @onclick="DismissUrgentModal"></button>
                </div>
                <div class="modal-body pt-0">
                    <p class="text-muted small mb-3">
                        @urgentTasks.Count tâche(s) à traiter dans les 7 prochains jours ou déjà en retard.
                    </p>
                    <ul class="list-unstyled mb-0">
                        @foreach (var task in urgentTasks)
                        {
                            var urgency = GetUrgency(task.Deadline);
                            <li class="task-row @urgency.CssClass mb-2">
                                <strong>@task.Title</strong>
                                <div class="d-flex justify-content-between align-items-center mt-1">
                                    <span class="small text-muted">@GetStatusLabel(task.Status)</span>
                                    <span class="badge @urgency.BadgeClass">@urgency.Label</span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-outline-secondary" @onclick="DismissUrgentModal">Plus tard</button>
                    <a href="/tasks" class="btn btn-danger" @onclick="DismissUrgentModal">Voir les tâches</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const int UrgentDays = 7;
    private const int UpcomingLimit = 4;
    private const int FilesLimit = 3;

    private DashboardStats dashboard = new();
    private bool isLoading = true;
    private bool isSyncing;
    private bool showUrgentModal;
    private string? syncMessage;

    private List<TaskItem> upcomingTasks = new();
    private List<TaskItem> urgentTasks = new();
    private List<DeliverableFile> latestFiles = new();

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
            Navigation.NavigateTo("/login", true);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            dashboard = await DashboardService.GetStatsAsync() ?? new();
            var allTasks = await TaskService.GetTasksAsync();
            var today = DateTime.Today;
            var urgentCutoff = today.AddDays(UrgentDays);

            var activeTasks = allTasks
                .Where(t => t.Status != "Done")
                .OrderBy(t => t.Deadline)
                .ToList();

            urgentTasks = activeTasks
                .Where(t => t.Deadline.Date <= urgentCutoff)
                .Select(t => new TaskItem
                {
                    Id = t.Id,
                    Title = t.Title,
                    Status = t.Status,
                    Deadline = t.Deadline
                })
                .ToList();

            upcomingTasks = activeTasks
                .Take(UpcomingLimit)
                .Select(t => new TaskItem
                {
                    Id = t.Id,
                    Title = t.Title,
                    Status = t.Status,
                    Deadline = t.Deadline
                })
                .ToList();

            latestFiles = (await Http.GetFromJsonAsync<List<DeliverableFile>>("api/deliverables/register") ?? new())
                .OrderByDescending(f => f.UploadDate)
                .Take(FilesLimit)
                .ToList();

            showUrgentModal = urgentTasks.Count > 0;
        }
        catch
        {
            dashboard.BackendStatus = "Erreur";
            dashboard.Database = "Inconnue";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void DismissUrgentModal() => showUrgentModal = false;

    private async Task TriggerEmailSync()
    {
        if (isSyncing) return;

        isSyncing = true;
        syncMessage = null;

        try
        {
            var response = await Http.PostAsync("api/sync/emails", null);
            syncMessage = response.IsSuccessStatusCode
                ? "Synchronisation lancée avec succès."
                : "Échec de la synchronisation. Réessayez.";
        }
        catch
        {
            syncMessage = "Backend inaccessible.";
        }
        finally
        {
            isSyncing = false;
        }
    }

    private static string GetStatusLabel(string status) => status switch
    {
        "Open" => "Ouverte",
        "InProgress" => "En cours",
        "Done" => "Terminée",
        _ => status
    };

    private static (string CssClass, string BadgeClass, string Label) GetUrgency(DateTime deadline)
    {
        var days = (deadline.Date - DateTime.Today).Days;

        if (days < 0)
            return ("overdue", "bg-danger", $"En retard ({Math.Abs(days)} j)");

        if (days == 0)
            return ("soon", "bg-danger", "Aujourd'hui");

        if (days <= UrgentDays)
            return ("soon", "bg-warning text-dark", $"Dans {days} j");

        return ("ok", "bg-success", deadline.ToString("dd/MM/yyyy"));
    }

    private class DeliverableFile
    {
        public int Id { get; set; }
        public string FileName { get; set; } = "";
        public DateTime UploadDate { get; set; }
        public string ProjectName { get; set; } = "";
    }
}
