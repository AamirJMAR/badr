@page "/categories"
@page "/projects"
@inject HttpClient Http

<div class="pmo-page">
    <PmoPageHeader Icon="📂"
                   Title="Categories"
                   Subtitle="Fixed categories for organizing tasks and deliverables." />

    <div class="card shadow-sm border-0 content-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0 data-table register-table">
                    <thead>
                        <tr>
                            <th class="ps-4">Name</th>
                            <th class="text-center">Tasks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in categories)
                        {
                            <tr class="data-row">
                                <td class="fw-semibold ps-4">@category.Name</td>
                                <td class="text-center">
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/categories/@category.Id/tasks"
                                       title="View tasks for this category">
                                        @category.TaskCount task@(category.TaskCount == 1 ? "" : "s")
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!categories.Any())
            {
                <div class="p-4">
                    <div class="empty-state-hint">
                        <div class="empty-state-icon">📂</div>
                        <div>
                            <div class="empty-state-title">No categories available</div>
                            <div class="empty-state-text">Categories are seeded automatically at startup.</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<CategoryDto> categories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/projects")
                     ?? new List<CategoryDto>();
    }

    private class CategoryDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public int TaskCount { get; set; }
    }
}
