@page "/emails/details/{Id:int}"
@using MyWebApp.Frontend.Constants
@using MyWebApp.Frontend.Helpers
@inject HttpClient Http
@inject NavigationManager Nav

<div class="pmo-page">
    <a href="/emails" class="back-link">← Back to emails</a>

    @if (email == null)
    {
        <div class="card shadow-sm border-0 loading-card content-card">
            <div class="card-body text-center py-5">
                <div class="loading-icon mb-3">📨</div>
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0 text-muted">Loading email...</p>
            </div>
        </div>
    }
    else
    {
        <PmoPageHeader Icon="📨"
                       Title="@email.Subject"
                       Subtitle="@($"From: {email.From}")">
            <HeaderActions>
                <button class="btn btn-info btn-sm" @onclick="AnalyzeWithAi" disabled="@isAnalyzing">
                    @if (isAnalyzing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Analyzing...</span>
                    }
                    else
                    {
                        <span>🤖 AI Analysis</span>
                    }
                </button>
            </HeaderActions>
        </PmoPageHeader>

        <div class="card shadow-sm border-0 mb-4 content-card">
            <div class="card-body p-4">
                <p style="white-space: pre-wrap;" class="mb-0">@email.Body</p>

                @if (!string.IsNullOrEmpty(aiError))
                {
                    <div class="alert alert-danger mt-3 mb-0">@aiError</div>
                }
            </div>
        </div>

    @if (analysis != null)
    {
        <div class="card shadow-sm mb-4 content-card">
            <div class="card-body p-4">
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Category</label>
                        <select class="form-select" @bind="selectedCategoryName">
                            @foreach (var cat in CategoryConstants.FixedCategories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Client</label>
                        <input class="form-control" value="@analysis.Client" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <select class="form-select" @bind="analysis.Status">
                            <option value="OnTrack">OnTrack</option>
                            <option value="AtRisk">AtRisk</option>
                            <option value="Delayed">Delayed</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <span class="badge @GetStatusBadgeClass(analysis.Status)">@analysis.Status</span>
                    <span class="badge bg-secondary ms-2">@analysis.Category</span>
                </div>

                <div class="mb-3">
                    <strong>Summary</strong>
                    <p>@analysis.Summary</p>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <button type="button" class="btn btn-outline-primary btn-sm me-2" @onclick="AddTask">
                        + Add task
                    </button>
                    <div class="text-muted small">You can delete tasks before using them.</div>
                </div>

                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Deadline</th>
                            <th style="width: 100px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < tasks.Count; i++)
                        {
                            var taskIndex = i;
                            <tr>
                                <td>
                                    <input class="form-control" @bind="tasks[taskIndex].Title" />
                                </td>
                                <td>
                                    <input type="date" class="form-control"
                                           @bind-value="tasks[taskIndex].Deadline"
                                           @bind-value:format="yyyy-MM-dd" />
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveTask(taskIndex)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="d-flex justify-content-center mt-3">
                    <button class="btn btn-success"
                            @onclick="CreateProjectTasks"
                            disabled="@(isCreatingTasks || !tasks.Any())">
                        @if (isCreatingTasks)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Creating tasks...</span>
                        }
                        else
                        {
                            <span>✅ Create tasks</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
    }

</div>

@code {
    [Parameter] public int Id { get; set; }

    private EmailDetailsDto? email;
    private EmailAnalysisResponse? analysis;
    private List<EmailTask> tasks = new();
    private string selectedCategoryName = CategoryConstants.DefaultCategory;
    private bool isAnalyzing;
    private bool isCreatingTasks;
    private string? aiError;

    protected override async Task OnInitializedAsync()
    {
        email = await Http.GetFromJsonAsync<EmailDetailsDto>($"api/emaillogs/details/{Id}");

        if (email?.AiAnalyzed == true)
        {
            analysis = new EmailAnalysisResponse
            {
                Client = string.Empty,
                Status = "OnTrack",
                Category = email.AiCategory ?? string.Empty,
                Summary = email.AiSummary ?? string.Empty,
                Tasks = ParseTasks(email.AiRecommendations)
            };
            tasks = analysis.Tasks.ToList();
            selectedCategoryName = CategoryConstants.DefaultCategory;
        }
    }

    private async Task AnalyzeWithAi()
    {
        if (email == null) return;

        isAnalyzing = true;
        aiError = null;
        analysis = null;
        tasks.Clear();

        try
        {
            var response = await Http.PostAsJsonAsync($"api/emaillogs/analyze-preview/{Id}", new { });
            if (!response.IsSuccessStatusCode)
            {
                var errBody = await response.Content.ReadAsStringAsync();
                aiError = string.IsNullOrWhiteSpace(errBody)
                    ? $"AI analysis failed: {response.ReasonPhrase}"
                    : $"AI analysis failed: {errBody}";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<EmailAnalysisResponse>();
            if (result == null)
            {
                aiError = "Unable to parse AI analysis response.";
                return;
            }

            analysis = result;
            selectedCategoryName = CategoryConstants.ResolveName(result.CategoryName ?? result.ProjectName);
            tasks = result.Tasks.Select(t => new EmailTask
            {
                Title = t.Title,
                Deadline = DeadlineHelper.Normalize(t.Deadline)
            }).ToList();
        }
        catch (Exception ex)
        {
            aiError = ex.Message;
        }
        finally
        {
            isAnalyzing = false;
        }
    }

    private void AddTask()
    {
        tasks.Add(new EmailTask { Title = string.Empty, Deadline = DeadlineHelper.DefaultDeadline });
    }

    private void RemoveTask(int index)
    {
        if (index >= 0 && index < tasks.Count)
            tasks.RemoveAt(index);
    }

    private async Task CreateProjectTasks()
    {
        if (analysis == null || !tasks.Any()) return;

        isCreatingTasks = true;
        aiError = null;

        try
        {
            var request = new CreateProjectTasksRequest
            {
                CategoryName = selectedCategoryName,
                Client = analysis.Client,
                Status = analysis.Status,
                Category = analysis.Category,
                Summary = analysis.Summary,
                Tasks = tasks.Select(t => new CreateTaskDto
                {
                    Title = t.Title,
                    Deadline = t.Deadline
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync($"api/emaillogs/create-project-tasks/{Id}", request);
            if (!response.IsSuccessStatusCode)
            {
                aiError = $"Failed to create tasks: {response.ReasonPhrase}";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<CreateResult>();
            if (result == null)
            {
                aiError = "Failed to create tasks.";
                return;
            }

            Nav.NavigateTo($"/categories/{result.ProjectId}/tasks");
        }
        catch (Exception ex)
        {
            aiError = ex.Message;
        }
        finally
        {
            isCreatingTasks = false;
        }
    }

    private List<EmailTask> ParseTasks(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<EmailTask>();

        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<EmailTask>>(json) ?? new List<EmailTask>();
        }
        catch
        {
            return new List<EmailTask>();
        }
    }

    private class CreateResult
    {
        public int ProjectId { get; set; }
    }

    private class CreateProjectTasksRequest
    {
        public string CategoryName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "OnTrack";
        public string Category { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public List<CreateTaskDto> Tasks { get; set; } = new();
    }

    private class CreateTaskDto
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; }
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "AtRisk" => "bg-warning text-dark",
        "Delayed" => "bg-danger",
        _ => "bg-success"
    };

    private void GoBack() => Nav.NavigateTo("/emails");

    class EmailDetailsDto
    {
        public int Id { get; set; }
        public string Subject { get; set; } = string.Empty;
        public string? From { get; set; }
        public string Body { get; set; } = string.Empty;
        public string? AiCategory { get; set; }
        public string? AiSummary { get; set; }
        public string? AiRecommendations { get; set; }
        public bool AiAnalyzed { get; set; }
    }

    class EmailAnalysisResponse
    {
        public string ProjectName { get; set; } = string.Empty;
        public string CategoryName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "OnTrack";
        public string Category { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public List<EmailTask> Tasks { get; set; } = new();
    }

    class EmailTask
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; } = DeadlineHelper.DefaultDeadline;
    }
}
