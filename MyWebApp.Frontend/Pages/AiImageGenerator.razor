@page "/ai-image-generator"
@inject HttpClient Http

<div class="pmo-page">
    <PmoPageHeader Icon="🎨"
                   Title="AI image generation"
                   Subtitle="Enter a description, then generate an image automatically." />

    <div class="card shadow-sm border-0 content-card">
        <div class="card-body p-4">
            <div class="mb-3">
                <label class="form-label fw-semibold">Image description</label>
                <textarea class="form-control" rows="3" @bind="prompt"></textarea>
            </div>

            <button class="btn btn-primary"
                    @onclick="GenerateImage"
                    disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Generating...</span>
                }
                else
                {
                    <span>Generate</span>
                }
            </button>

            @if (!string.IsNullOrWhiteSpace(imageUrl))
            {
                <div class="mt-4">
                    <img src="@imageUrl" class="img-fluid rounded shadow" alt="Generated image" />
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string prompt = "";
    private bool isLoading = false;
    private string? imageUrl;

    private async Task GenerateImage()
    {
        isLoading = true;
        imageUrl = null;

        var response = await Http.PostAsJsonAsync(
            "api/image/generate",
            new { Prompt = prompt }
        );

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content
                .ReadFromJsonAsync<ImageResult>();
            imageUrl = result?.ImageUrl;
        }

        isLoading = false;
    }

    private class ImageResult
    {
        public string ImageUrl { get; set; } = "";
    }
}
