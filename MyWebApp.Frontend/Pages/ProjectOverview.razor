@page "/projects/{ProjectId:int}/overview"
@inject HttpClient Http
@using Microsoft.AspNetCore.Components

<div class="pmo-page">

    @if (overview == null || project == null)
    {
        <div class="card shadow-sm border-0 loading-card content-card">
            <div class="card-body text-center py-5">
                <div class="loading-icon mb-3">📊</div>
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0 text-muted">Loading category overview...</p>
            </div>
        </div>
    }
    else
    {
        <PmoPageHeader Icon="📊"
                       Title="@($"{project.Name} — Category Overview")"
                       Subtitle="Overall progress for this category.">
            <HeaderActions>
                <span class="badge @GetProjectBadgeClass(project.Status) fs-6">@project.Status</span>
            </HeaderActions>
        </PmoPageHeader>

        <!-- KPI CARDS -->
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 kpi-tile">
                    <div class="card-body text-center">
                        <h6>Total Tasks</h6>
                        <h2 class="fw-bold">@overview.Total</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-success">
                    <div class="card-body text-center">
                        <h6>Done</h6>
                        <h2 class="fw-bold text-success">@overview.Done</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-info">
                    <div class="card-body text-center">
                        <h6>In Progress</h6>
                        <h2 class="fw-bold text-info">@overview.InProgress</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-warning">
                    <div class="card-body text-center">
                        <h6>Open</h6>
                        <h2 class="fw-bold text-warning">@overview.Open</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- COMPLETION -->
        <div class="card shadow-sm border-primary mt-4">
            <div class="card-body text-center">
                <h6>Completion Rate</h6>
                <h2 class="fw-bold">@overview.CompletionRate %</h2>
            </div>
        </div>
    }

</div>

@code {

    [Parameter]
    public int ProjectId { get; set; }

    private ProjectDto? project;
    private ProjectOverviewDto? overview;

    protected override async Task OnInitializedAsync()
    {
        project = await Http.GetFromJsonAsync<ProjectDto>($"api/projects/{ProjectId}");
        overview = await Http.GetFromJsonAsync<ProjectOverviewDto>(
            $"api/reports/project/{ProjectId}");
    }

    private string GetProjectBadgeClass(string status) => status switch
    {
        "OnTrack" => "bg-success",
        "AtRisk" => "bg-warning text-dark",
        "Delayed" => "bg-danger",
        _ => "bg-secondary"
    };

    private class ProjectDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Status { get; set; } = "";
    }

    private class ProjectOverviewDto
    {
        public int Total { get; set; }
        public int Done { get; set; }
        public int Open { get; set; }
        public int InProgress { get; set; }
        public int CompletionRate { get; set; }
    }
}