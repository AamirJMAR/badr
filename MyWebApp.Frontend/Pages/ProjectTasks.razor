@page "/categories/{ProjectId:int}/tasks"
@page "/projects/{ProjectId:int}/tasks"
@inject HttpClient Http
@using Microsoft.AspNetCore.Components

<div class="pmo-page">

    @if (category == null)
    {
        <div class="card shadow-sm border-0 loading-card content-card">
            <div class="card-body text-center py-5">
                <div class="loading-icon mb-3">📂</div>
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0 text-muted">Loading...</p>
            </div>
        </div>
    }
    else
    {
        <a href="/categories" class="back-link">← Back to categories</a>

        <PmoPageHeader Icon="📂"
                       Title="@category.Name"
                       Subtitle="@($"Deadline: {category.Deadline:dd MMM yyyy} — {category.TaskCount} task{(category.TaskCount == 1 ? "" : "s")}")">
            <HeaderActions>
                <span class="badge @GetStatusClass(category.Status) fs-6">@GetStatusLabel(category.Status)</span>
            </HeaderActions>
        </PmoPageHeader>

        <div class="card shadow-sm border-0 content-card">
            <div class="card-body p-0">
                @if (tasks.Count == 0)
                {
                    <div class="p-4">
                        <div class="empty-state-hint">
                            <div class="empty-state-icon">✅</div>
                            <div>
                                <div class="empty-state-title">No tasks yet</div>
                                <div class="empty-state-text">No tasks linked to this category.</div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 data-table register-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Title</th>
                                    <th>Deadline</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in tasks)
                                {
                                    <tr class="data-row">
                                        <td class="ps-4">
                                            <a href="/tasks/@task.Id" class="text-decoration-none fw-bold">
                                                @task.Title
                                            </a>
                                        </td>
                                        <td>@task.Deadline.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge @GetTaskStatusClass(task.Status)">
                                                @task.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

</div>

@code {
    [Parameter]
    public int ProjectId { get; set; }

    private CategoryDto? category;
    private List<TaskItem> tasks = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategory();
        await LoadTasks();
    }

    private async Task LoadCategory()
    {
        category = await Http.GetFromJsonAsync<CategoryDto>($"api/projects/{ProjectId}");
    }

    private async Task LoadTasks()
    {
        tasks = await Http.GetFromJsonAsync<List<TaskItem>>($"api/tasks?projectId={ProjectId}")
                ?? new List<TaskItem>();

        if (category != null)
            category.TaskCount = tasks.Count;
    }

    private static string GetStatusClass(string status) => status switch
    {
        "OnTrack" => "bg-success",
        "AtRisk" => "bg-warning text-dark",
        "Delayed" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetStatusLabel(string status) => status switch
    {
        "OnTrack" => "On track",
        "AtRisk" => "At risk",
        "Delayed" => "Overdue",
        _ => status
    };

    private static string GetTaskStatusClass(string status) => status switch
    {
        "Open" => "bg-warning text-dark",
        "InProgress" => "bg-info",
        "Done" => "bg-success",
        _ => "bg-secondary"
    };

    private class TaskItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public DateTime Deadline { get; set; }
        public string Status { get; set; } = "";
    }

    private class CategoryDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public DateTime Deadline { get; set; }
        public string Status { get; set; } = "";
        public int TaskCount { get; set; }
    }
}
