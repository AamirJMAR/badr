@page "/pmo"

<div class="pmo-page">

    <PmoPageHeader Icon="🏢"
                   Title="PMO Control & Governance Center"
                   Subtitle="Centralized view of PMO activities supporting complex programs. Visibility, control, and decision support across the lifecycle." />

    <!-- === KPI OVERVIEW === -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center kpi-tile">
                <div class="card-body">
                    <h2 class="fw-bold">24</h2>
                    <p class="text-muted">Active Projects</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center kpi-tile">
                <div class="card-body">
                    <h2 class="fw-bold text-warning">5</h2>
                    <p class="text-muted">High Risk Items</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center kpi-tile">
                <div class="card-body">
                    <h2 class="fw-bold text-success">92%</h2>
                    <p class="text-muted">Milestones On Track</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center kpi-tile">
                <div class="card-body">
                    <h2 class="fw-bold">+18%</h2>
                    <p class="text-muted">Reporting Efficiency</p>
                </div>
            </div>
        </div>
    </div>

    <!-- === PMO DOMAINS === -->
    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 kpi-tile">
                <div class="card-body">
                    <h5 class="fw-bold">Project Planning & Control</h5>
                    <p class="text-muted">
                        Definition and consolidation of project plans,
                        milestones, timelines, workload distribution
                        and dependency management across programs.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 kpi-tile">
                <div class="card-body">
                    <h5 class="fw-bold">Risk & Issue Management</h5>
                    <p class="text-muted">
                        Identification, monitoring and anticipation of
                        project risks and issues impacting cost,
                        schedule or quality objectives.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 kpi-tile">
                <div class="card-body">
                    <h5 class="fw-bold">Performance Reporting & KPIs</h5>
                    <p class="text-muted">
                        Consolidated dashboards, KPI tracking and
                        reporting to support informed and timely
                        management decisions.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 kpi-tile">
                <div class="card-body">
                    <h5 class="fw-bold">Governance & Compliance</h5>
                    <p class="text-muted">
                        Governance framework implementation, quality
                        gates, validation processes and alignment
                        with organizational and client standards.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 kpi-tile">
                <div class="card-body">
                    <h5 class="fw-bold">Stakeholder Communication</h5>
                    <p class="text-muted">
                        Coordination between project teams,
                        management, and stakeholders through
                        clear and structured communication channels.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 kpi-tile">
                <div class="card-body">
                    <h5 class="fw-bold">Continuous Improvement</h5>
                    <p class="text-muted">
                        Capitalization of lessons learned, process
                        optimization and introduction of digital and
                        automation enablers to improve PMO efficiency.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- === QUICK ACTIONS === -->
    <div class="mt-5">
        <h5 class="fw-bold mb-3">PMO Quick Actions</h5>

        <div class="d-flex gap-3 flex-wrap">
            <button class="btn btn-primary">View Project Dashboard</button>
            <button class="btn btn-outline-primary">Risk Register</button>
            <button class="btn btn-outline-secondary">Generate Report</button>
            <button class="btn btn-outline-dark">Sync Outlook & Calendar</button>
        </div>
    </div>

</div>