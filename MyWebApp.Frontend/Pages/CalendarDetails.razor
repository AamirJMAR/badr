@page "/calendar/details/{Id:int}"
@inject HttpClient Http
@inject NavigationManager Navigation

<h1 class="fw-bold mb-4">📅 Meeting Details</h1>

@if (calendarEvent == null)
{
    <div class="alert alert-info">
        Loading meeting details...
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h4 class="card-title mb-1">📌 @calendarEvent.Subject</h4>
                    <p class="text-muted mb-0">
                        🕒 @FormatDate(calendarEvent.StartTime) → @FormatDate(calendarEvent.EndTime)
                    </p>
                </div>
                <button class="btn btn-info btn-sm" @onclick="AnalyzeCalendarEvent" disabled="@isAnalyzing">
                    @if (isAnalyzing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Analyzing...</span>
                    }
                    else
                    {
                        <span>🤖 AI Analysis</span>
                    }
                </button>
            </div>

            <hr />

            <p class="card-text">
                👤 <strong>Organizer</strong><br />
                @calendarEvent.Organizer
            </p>

            <hr />

            <p class="card-text">
                👥 <strong>Required Attendees</strong>
            </p>

            @if (string.IsNullOrWhiteSpace(calendarEvent.RequiredAttendees))
            {
                <p class="text-muted">No required attendees</p>
            }
            else
            {
                <ul>
                    @foreach (var att in SplitAttendees(calendarEvent.RequiredAttendees))
                    {
                        <li>@att</li>
                    }
                </ul>
            }

            <p class="card-text mt-3">
                👥 <strong>Optional Attendees</strong>
            </p>

            @if (string.IsNullOrWhiteSpace(calendarEvent.OptionalAttendees))
            {
                <p class="text-muted">No optional attendees</p>
            }
            else
            {
                <ul>
                    @foreach (var att in SplitAttendees(calendarEvent.OptionalAttendees))
                    {
                        <li>@att</li>
                    }
                </ul>
            }

            @if (!string.IsNullOrEmpty(aiError))
            {
                <div class="alert alert-danger mt-3">@aiError</div>
            }

            <hr />

            <button class="btn btn-secondary" @onclick="GoBack">
                ⬅ Back to Calendar
            </button>
        </div>
    </div>
}

@if (analysis != null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Project</label>
                    <input class="form-control" @bind="analysis.ProjectName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Client</label>
                    <input class="form-control" @bind="analysis.Client" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="analysis.Status">
                        <option value="OnTrack">OnTrack</option>
                        <option value="AtRisk">AtRisk</option>
                        <option value="Delayed">Delayed</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <span class="badge @GetStatusBadgeClass(analysis.Status)">@analysis.Status</span>
                <span class="badge bg-secondary ms-2">@analysis.Category</span>
            </div>

            @if (analysis != null && IsActionRequired())
            {
                <div class="alert alert-warning">
                    <strong>Action required:</strong> vérifiez les tâches et le statut si besoin.
                </div>
            }

            <div class="mb-3">
                <strong>Summary</strong>
                <p>@analysis.Summary</p>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <button type="button" class="btn btn-outline-primary btn-sm me-2" @onclick="AddTask">
                        + Add task
                    </button>
                </div>
                <div class="text-muted small">You can delete tasks before reviewing.</div>
            </div>

            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Task</th>
                        <th>Deadline</th>
                        <th style="width: 100px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < tasks.Count; i++)
                    {
                        var taskIndex = i;
                        <tr>
                            <td>
                                <input class="form-control" @bind="tasks[taskIndex].Title" />
                            </td>
                            <td>
                                <input class="form-control" @bind="tasks[taskIndex].Deadline" placeholder="yyyy-MM-dd or TBD" />
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveTask(taskIndex)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (analysis != null && tasks.Any())
{
    <div class="d-flex justify-content-center mt-3">
        <button class="btn btn-success"
                @onclick="CheckBeforeCreate"
                disabled="@isCreatingTasks">
            @if (isCreatingTasks)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Creating tasks...</span>
            }
            else
            {
                <span>✅ Create tasks in project</span>
            }
        </button>
    </div>
}

@if (showConfirm)
{
    <div class="alert alert-warning mt-4">
        <strong>Project already exists</strong>
        <p>
            The project <strong>@(analysis?.ProjectName ?? calendarEvent?.Subject)</strong> already exists.<br />
            Do you want to add the detected tasks to this project?
        </p>

        <button class="btn btn-success me-2" @onclick="CreateProjectTasks">
            ✅ Confirm
        </button>

        <button class="btn btn-secondary" @onclick="() => showConfirm = false">
            ❌ Cancel
        </button>
    </div>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private CalendarEvent? calendarEvent;
    private CalendarAnalysisResponse? analysis;
    private List<CalendarTask> tasks = new();
    private bool isAnalyzing = false;
    private bool isCreatingTasks = false;
    private bool showConfirm = false;
    private string? aiError;

    protected override async Task OnInitializedAsync()
    {
        calendarEvent = await Http.GetFromJsonAsync<CalendarEvent>($"api/calendar/{Id}");

        if (calendarEvent?.AiAnalyzed == true)
        {
            analysis = new CalendarAnalysisResponse
            {
                ProjectName = calendarEvent.AiProjectName ?? string.Empty,
                Client = calendarEvent.AiClient ?? string.Empty,
                Status = calendarEvent.AiStatus ?? "OnTrack",
                Category = calendarEvent.AiCategory ?? string.Empty,
                Summary = calendarEvent.AiSummary ?? string.Empty,
                Tasks = ParseTasks(calendarEvent.AiRecommendations)
            };
            tasks = analysis.Tasks.ToList();
        }
    }

    private async Task AnalyzeCalendarEvent()
    {
        if (calendarEvent == null)
            return;

        isAnalyzing = true;
        aiError = null;
        analysis = null;
        tasks.Clear();

        try
        {
            var response = await Http.PostAsJsonAsync($"api/calendar/analyze-preview/{Id}", new { });
            if (!response.IsSuccessStatusCode)
            {
                var errBody = await response.Content.ReadAsStringAsync();
                aiError = string.IsNullOrWhiteSpace(errBody)
                    ? $"Analyse IA échouée : {response.ReasonPhrase}"
                    : $"Analyse IA échouée : {errBody}";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<CalendarAnalysisResponse>();
            if (result == null)
            {
                aiError = "Unable to parse AI analysis response.";
                return;
            }

            analysis = result;
            tasks = result.Tasks.ToList();
        }
        catch (Exception ex)
        {
            aiError = ex.Message;
        }
        finally
        {
            isAnalyzing = false;
        }
    }

    private void AddTask()
    {
        tasks.Add(new CalendarTask { Title = string.Empty, Deadline = "TBD" });
    }

    private void RemoveTask(int index)
    {
        if (index >= 0 && index < tasks.Count)
        {
            tasks.RemoveAt(index);
        }
    }

    private async Task CheckBeforeCreate()
    {
        if (analysis == null || !tasks.Any())
            return;

        isCreatingTasks = true;
        showConfirm = false;
        aiError = null;

        try
        {
            var projectName = string.IsNullOrWhiteSpace(analysis.ProjectName)
                ? calendarEvent?.Subject ?? "Calendar Project"
                : analysis.ProjectName;

            var response = await Http.PostAsJsonAsync("api/calendar/check-project", projectName);
            var result = await response.Content.ReadFromJsonAsync<ProjectCheckResult>();

            if (result == null)
            {
                aiError = "Unable to verify project.";
                return;
            }

            if (result.Exists)
            {
                showConfirm = true;
            }
            else
            {
                await CreateProjectTasks();
            }
        }
        catch (Exception ex)
        {
            aiError = ex.Message;
        }
        finally
        {
            isCreatingTasks = false;
        }
    }

    private async Task CreateProjectTasks()
    {
        if (analysis == null || !tasks.Any())
            return;

        isCreatingTasks = true;
        showConfirm = false;
        aiError = null;

        try
        {
            var request = new CreateProjectTasksRequest
            {
                ProjectName = string.IsNullOrWhiteSpace(analysis.ProjectName)
                    ? calendarEvent?.Subject ?? "Calendar Project"
                    : analysis.ProjectName,
                Client = analysis.Client,
                Status = analysis.Status,
                Category = analysis.Category,
                Summary = analysis.Summary,
                Tasks = tasks.Select(t => new CreateTaskDto
                {
                    Title = t.Title,
                    Deadline = DateTime.TryParse(t.Deadline, out var date)
                        ? date
                        : DateTime.UtcNow
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync($"api/calendar/create-project-tasks/{Id}", request);
            if (!response.IsSuccessStatusCode)
            {
                aiError = $"Failed to create tasks: {response.ReasonPhrase}";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<CreateResult>();
            if (result == null)
            {
                aiError = "Failed to create tasks.";
                return;
            }

            Navigation.NavigateTo($"/categories/{result.ProjectId}/tasks");
        }
        catch (Exception ex)
        {
            aiError = ex.Message;
        }
        finally
        {
            isCreatingTasks = false;
        }
    }

    private List<CalendarTask> ParseTasks(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<CalendarTask>();

        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<CalendarTask>>(json) ?? new List<CalendarTask>();
        }
        catch
        {
            return new List<CalendarTask>();
        }
    }

    private class ProjectCheckResult
    {
        public bool Exists { get; set; }
    }

    private class CreateResult
    {
        public int ProjectId { get; set; }
    }

    private class CreateProjectTasksRequest
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "OnTrack";
        public string Category { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public List<CreateTaskDto> Tasks { get; set; } = new();
    }

    private class CreateTaskDto
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/calendar");
    }

    private string FormatDate(DateTime? date)
    {
        if (date == null)
            return "N/A";

        return date.Value.ToString("dd/MM/yyyy HH:mm");
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "AtRisk" => "bg-warning text-dark",
        "Delayed" => "bg-danger",
        _ => "bg-success"
    };

    private bool IsActionRequired()
    {
        if (analysis == null)
            return false;

        return analysis.Category?.Contains("Action Required", StringComparison.OrdinalIgnoreCase) == true
            || analysis.Status == "AtRisk"
            || analysis.Status == "Delayed";
    }

    private IEnumerable<string> SplitAttendees(string attendees)
    {
        // Nettoyage simple du texte renvoyé par Power Automate
        return attendees
            .Replace("[", "")
            .Replace("]", "")
            .Replace("\"", "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(a => a.Trim());
    }

    private class CalendarEvent
    {
        public int Id { get; set; }
        public string Subject { get; set; } = "";
        public DateTime? StartTime { get; set; }
        public DateTime? EndTime { get; set; }
        public string? Organizer { get; set; }
        public string? RequiredAttendees { get; set; }
        public string? OptionalAttendees { get; set; }

        public string? AiProjectName { get; set; }
        public string? AiClient { get; set; }
        public string? AiStatus { get; set; }
        public string? AiCategory { get; set; }
        public string? AiSummary { get; set; }
        public string? AiRecommendations { get; set; }
        public bool AiAnalyzed { get; set; }
    }

    private class CalendarAnalysisResponse
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "OnTrack";
        public string Category { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public List<CalendarTask> Tasks { get; set; } = new();
    }

    private class CalendarTask
    {
        public string Title { get; set; } = string.Empty;
        public string Deadline { get; set; } = string.Empty;
    }
}
