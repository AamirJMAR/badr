@page "/users"
@using System.Net.Http.Json
@inject HttpClient Http

<div class="pmo-page">
    <PmoPageHeader Icon="👤"
                   Title="Users"
                   Subtitle="Manage team access and user accounts.">
        <HeaderActions>
            @if (users != null)
            {
                <span class="badge bg-primary me-2">Total: @users.Count</span>
            }
            <button class="btn btn-success btn-sm" @onclick="() => showModal = true">
                + Add user
            </button>
        </HeaderActions>
    </PmoPageHeader>

    <div class="card shadow-sm border-0 content-card">
        <div class="card-body p-0">
            @if (users == null)
            {
                <div class="text-center py-5">
                    <div class="loading-icon mb-3">👤</div>
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 mb-0 text-muted">Loading...</p>
                </div>
            }
            else if (users.Count == 0)
            {
                <div class="p-4">
                    <div class="empty-state-hint">
                        <div class="empty-state-icon">👤</div>
                        <div>
                            <div class="empty-state-title">No users found</div>
                            <div class="empty-state-text">Add your first user to get started.</div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 data-table register-table">
                        <thead>
                            <tr>
                                <th class="ps-4">Id</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in users)
                            {
                                <tr class="data-row">
                                    <td class="ps-4">@user.Id</td>
                                    <td class="fw-semibold">@user.Name</td>
                                    <td>@user.Email</td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteUser(user.Id)">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    
string newName = "";
string newEmail = "";

    bool showModal = false;
    List<User>? users;

    protected override async Task OnInitializedAsync()
    {
        users = await Http.GetFromJsonAsync<List<User>>("api/users");
    }

    public class User
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
    }
    async Task SaveUser()
{
    var user = new User
    {
        Name = newName,
        Email = newEmail
    };

    await Http.PostAsJsonAsync("api/users", user);

    users = await Http.GetFromJsonAsync<List<User>>("api/users");

    newName = "";
    newEmail = "";

    showModal = false;
}

async Task DeleteUser(int id)
{
    await Http.DeleteAsync($"api/users/{id}");

    users = await Http.GetFromJsonAsync<List<User>>("api/users");
}

    
}
@if (showModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content app-modal border-0 shadow">
                <div class="modal-header bg-light border-0">
                    <h5 class="modal-title fw-bold">Add user</h5>
                    <button class="btn-close" @onclick="() => showModal = false"></button>
                </div>
<div class="modal-body">
    <div class="mb-3">
        <label class="form-label">Name</label>

<input class="form-control" placeholder="Enter name" @bind="newName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
<input class="form-control" placeholder="Enter email" @bind="newEmail" />    </div>
</div>

<div class="modal-footer border-0">
    <button class="btn btn-secondary" @onclick="() => showModal = false">
        Cancel
    </button>
<button class="btn btn-primary" @onclick="SaveUser">
    Save
</button>

</div>
            </div>
        </div>
    </div>
}
