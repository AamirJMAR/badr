@page "/deliverables"
@using MyWebApp.Frontend.Constants
@using MyWebApp.Frontend.Helpers
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="pmo-page deliverables-page">
    <div class="page-header mb-4">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <div class="page-title-wrap">
                    <span class="page-title-icon">📄</span>
                    <div>
                        <h1 class="page-title mb-1">Deliverables</h1>
                        <p class="page-subtitle mb-0">
                            Upload a document to register it or run AI analysis.
                        </p>
                    </div>
                </div>
            </div>

            <div class="header-actions">
                <button class="btn btn-outline-primary btn-sm" @onclick="GoToRegister">
                    📁 View register
                </button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 upload-card">
        <div class="card-body p-4">
            <div class="section-heading mb-4">
                <h5 class="fw-bold mb-1">Upload a document</h5>
                <p class="text-muted small mb-0">
                    Select a file, choose an action, then confirm.
                </p>
            </div>

            <div class="upload-zone mb-4">
                <div class="upload-zone-icon">⬆️</div>
                <div class="upload-zone-content">
                    <div class="upload-zone-title">Import a file</div>
                    <div class="upload-zone-text">
                        PDF or project tracking document to register.
                    </div>
                </div>

                <div class="upload-input-wrap">
                    <InputFile OnChange="HandleFileSelected" class="upload-input" />
                </div>
            </div>

            @if (fileSelected)
            {
                <div class="selected-file-banner mb-4">
                    <div class="selected-file-icon">📎</div>
                    <div class="selected-file-info">
                        <div class="selected-file-label">Selected file</div>
                        <div class="selected-file-name">@selectedFileName</div>
                    </div>
                    <span class="badge bg-success-subtle text-success-emphasis selected-badge">Ready</span>
                </div>

                <div class="form-section mb-4">
                    <div class="form-section-title">Action after upload</div>
                    <div class="form-section-subtitle">
                        Choose what to do after importing the document.
                    </div>

                    <div class="action-options mt-3">
                        <div class="action-option-item">
                            <input class="btn-check" type="radio" id="storeOnly" name="actionAfter" value="store" @onchange="SetAction" checked="@(selectedAction == "store")" />
                            <label class="action-tile" for="storeOnly">
                                <div class="action-tile-icon">💾</div>
                                <div class="action-tile-content">
                                    <div class="action-tile-title">Store only</div>
                                    <div class="action-tile-text">Add the document to the register without AI analysis.</div>
                                </div>
                            </label>
                        </div>

                        <div class="action-option-item">
                            <input class="btn-check" type="radio" id="analyzeOnly" name="actionAfter" value="analyze" @onchange="SetAction" checked="@(selectedAction == "analyze")" />
                            <label class="action-tile" for="analyzeOnly">
                                <div class="action-tile-icon">🤖</div>
                                <div class="action-tile-content">
                                    <div class="action-tile-title">Analyze only</div>
                                    <div class="action-tile-text">Extract tasks without saving to the register.</div>
                                </div>
                            </label>
                        </div>

                        <div class="action-option-item">
                            <input class="btn-check" type="radio" id="storeAnalyze" name="actionAfter" value="store_analyze" @onchange="SetAction" checked="@(selectedAction == "store_analyze")" />
                            <label class="action-tile" for="storeAnalyze">
                                <div class="action-tile-icon">⚡</div>
                                <div class="action-tile-content">
                                    <div class="action-tile-title">Store + analyze</div>
                                    <div class="action-tile-text">Save the document and extract tasks automatically.</div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-section mb-4">
                    <div class="row g-3">
                        <div class="col-lg-8">
                            <label class="form-label fw-semibold">Category</label>
                            <select class="form-select form-select-lg" @bind="selectedCategoryName">
                                @foreach (var cat in CategoryConstants.FixedCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                            <div class="form-text">Choose the category for this deliverable.</div>
                        </div>

                        <div class="col-lg-4">
                            <label class="form-label fw-semibold">Selected mode</label>
                            <div class="selected-action-box">
                                @if (selectedAction == "store")
                                {
                                    <span class="badge text-bg-primary fs-6">💾 Store only</span>
                                }
                                else if (selectedAction == "analyze")
                                {
                                    <span class="badge text-bg-warning fs-6">🤖 Analyze only</span>
                                }
                                else if (selectedAction == "store_analyze")
                                {
                                    <span class="badge text-bg-success fs-6">⚡ Store + analyze</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state-hint">
                    <div class="empty-state-icon">ℹ️</div>
                    <div>
                        <div class="empty-state-title">No file selected</div>
                        <div class="empty-state-text">
                            Choose a document first. Action options will appear automatically.
                        </div>
                    </div>
                </div>
            }

            <div class="action-bar mt-4">
                <button class="btn btn-primary btn-lg px-4" @onclick="SaveFile" disabled="@(!fileSelected || isSaving)">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Processing...</span>
                    }
                    else if (selectedAction == "analyze")
                    {
                        <span>🤖 Run analysis</span>
                    }
                    else if (selectedAction == "store_analyze")
                    {
                        <span>⚡ Store and analyze</span>
                    }
                    else
                    {
                        <span>💾 Save file</span>
                    }
                </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-4 mb-0" role="alert">
                    <div class="fw-semibold mb-1">An error occurred</div>
                    <div>@errorMessage</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success mt-4 mb-0" role="alert">
                    <div class="fw-semibold mb-1">Success</div>
                    <div>@successMessage</div>
                    <div class="mt-3">
                        <button class="btn btn-sm btn-outline-success" @onclick="GoToRegister">
                            View deliverables register
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="analysisModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold">📋 AI Analysis — Extracted tasks</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                @if (analysisLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border" role="status"></div>
                        <p class="mt-3 mb-0 text-muted">Extracting and analyzing...</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(analysisError))
                {
                    <div class="alert alert-danger">@analysisError</div>
                }
                else if (editableTasks != null)
                {
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Category</label>
                            <select class="form-select" @bind="editableCategoryName">
                                @foreach (var cat in CategoryConstants.FixedCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Client</label>
                            <input class="form-control" @bind="editableClient" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddEditableTask">
                            + Add task
                        </button>
                        <div class="text-muted small">Edit or remove tasks before creating.</div>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Task</th>
                                    <th style="width: 180px;">Deadline</th>
                                    <th style="width: 120px;" class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < editableTasks.Count; i++)
                                {
                                    var taskIndex = i;
                                    <tr>
                                        <td>
                                            <input class="form-control form-control-sm" @bind="editableTasks[taskIndex].Title" />
                                        </td>
                                        <td>
                                            <input type="date" class="form-control form-control-sm"
                                                   @bind-value="editableTasks[taskIndex].Deadline"
                                                   @bind-value:format="yyyy-MM-dd" />
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveEditableTask(taskIndex)">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" @onclick="CreateTasksFromAnalysisEditable"
                        disabled="@(editableTasks == null || editableTasks.Count == 0 || isCreatingTasks)">
                    @if (isCreatingTasks)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <span>✅ Create tasks</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private IBrowserFile? uploadedFile;
    private bool fileSelected;
    private bool isSaving;
    private string selectedFileName = string.Empty;
    private string selectedCategoryName = CategoryConstants.DefaultCategory;
    private string selectedAction = "store";
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        fileSelected = uploadedFile != null;
        selectedFileName = uploadedFile?.Name ?? string.Empty;
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    private void SetAction(ChangeEventArgs e) => selectedAction = e.Value?.ToString() ?? "store";

    private async Task SaveFile()
    {
        if (uploadedFile == null) return;

        isSaving = true;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(uploadedFile.OpenReadStream(20_000_000));
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                uploadedFile.ContentType ?? "application/pdf");
            content.Add(streamContent, "file", uploadedFile.Name);
            content.Add(new StringContent(selectedCategoryName), "categoryName");

            if (selectedAction == "store")
            {
                var response = await Http.PostAsync("api/deliverables/upload", content);
                if (!response.IsSuccessStatusCode)
                {
                    var errBody = await response.Content.ReadAsStringAsync();
                    errorMessage = string.IsNullOrWhiteSpace(errBody)
                        ? $"Upload failed: {response.ReasonPhrase}"
                        : $"Upload failed: {errBody}";
                    return;
                }

                var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                successMessage = result != null
                    ? $"File \"{result.FileName}\" saved under category \"{result.CategoryName}\"."
                    : "File saved successfully.";
            }
            else if (selectedAction == "analyze")
            {
                var aiUpload = await Http.PostAsync("api/ai/upload", content);
                if (!aiUpload.IsSuccessStatusCode)
                {
                    errorMessage = "Analysis failed: unable to extract text.";
                    return;
                }

                var uploadResp = await aiUpload.Content.ReadFromJsonAsync<AiUploadResp>();
                if (uploadResp == null)
                {
                    errorMessage = "Invalid analysis response.";
                    return;
                }

                var extractResp = await Http.PostAsJsonAsync("api/ai/extract-tasks", new { Text = uploadResp.FullText });
                if (!extractResp.IsSuccessStatusCode)
                {
                    errorMessage = "AI analysis failed.";
                    return;
                }

                var tasks = await extractResp.Content.ReadFromJsonAsync<ExtractTasksResponseLocal>();
                successMessage = tasks != null
                    ? $"Analysis complete — {tasks.Tasks?.Count ?? 0} tasks detected."
                    : "Analysis complete.";
            }
            else if (selectedAction == "store_analyze")
            {
                var aiUpload = await Http.PostAsync("api/ai/upload", content);
                if (!aiUpload.IsSuccessStatusCode)
                {
                    errorMessage = "AI upload failed.";
                    return;
                }

                var uploadResp = await aiUpload.Content.ReadFromJsonAsync<AiUploadResp>();
                if (uploadResp == null)
                {
                    errorMessage = "Invalid AI upload response.";
                    return;
                }

                var extractResp = await Http.PostAsJsonAsync("api/ai/extract-tasks", new { Text = uploadResp.FullText });
                if (!extractResp.IsSuccessStatusCode)
                {
                    errorMessage = "AI analysis failed.";
                    return;
                }

                var tasks = await extractResp.Content.ReadFromJsonAsync<ExtractTasksResponseLocal>();
                await ShowAnalysisModal(tasks, uploadResp);
                return;
            }

            uploadedFile = null;
            fileSelected = false;
            selectedFileName = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoToRegister() => Navigation.NavigateTo("/deliverables-register");

    private bool analysisLoading;
    private string analysisError = string.Empty;
    private List<EditableTask>? editableTasks;
    private string editableCategoryName = CategoryConstants.DefaultCategory;
    private string editableClient = string.Empty;
    private bool isCreatingTasks;
    private string? tempStoredFileName;

    private async Task ShowAnalysisModal(ExtractTasksResponseLocal? tasks, AiUploadResp uploadResp)
    {
        editableCategoryName = CategoryConstants.ResolveName(tasks?.ProjectName);
        editableClient = tasks?.Client ?? string.Empty;
        editableTasks = (tasks?.Tasks ?? new()).Select(t => new EditableTask
        {
            Title = t.Title,
            Deadline = DeadlineHelper.ParseDeadline(t.Deadline)
        }).ToList();
        tempStoredFileName = uploadResp.StoredFileName;
        analysisError = string.Empty;
        analysisLoading = false;
        await JS.InvokeVoidAsync("bootstrapModal.show", "analysisModal");
    }

    private void AddEditableTask() =>
        editableTasks?.Add(new EditableTask { Title = string.Empty, Deadline = DeadlineHelper.DefaultDeadline });

    private void RemoveEditableTask(int index)
    {
        if (editableTasks != null && index >= 0 && index < editableTasks.Count)
            editableTasks.RemoveAt(index);
    }

    private async Task CreateTasksFromAnalysisEditable()
    {
        if (editableTasks == null || editableTasks.Count == 0) return;

        isCreatingTasks = true;
        analysisError = string.Empty;

        try
        {
            var createPayload = new CreateTasksLocal
            {
                CategoryName = editableCategoryName,
                Client = editableClient ?? string.Empty,
                Status = "Open",
                FileName = selectedFileName,
                StoredFileName = tempStoredFileName ?? string.Empty,
                Tasks = editableTasks.Select(t => new CreateTaskItem { Title = t.Title, Deadline = t.Deadline }).ToList()
            };

            var createResp = await Http.PostAsJsonAsync("api/deliverables/create-tasks", createPayload);
            if (!createResp.IsSuccessStatusCode)
            {
                analysisError = "Failed to create tasks.";
                return;
            }

            await JS.InvokeVoidAsync("bootstrapModal.hide", "analysisModal");
            successMessage = "File and tasks saved successfully.";
            uploadedFile = null;
            fileSelected = false;
            selectedFileName = string.Empty;
            editableTasks = null;
            tempStoredFileName = null;
        }
        catch (Exception ex)
        {
            analysisError = ex.Message;
        }
        finally
        {
            isCreatingTasks = false;
        }
    }

    private class EditableTask
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; } = DeadlineHelper.DefaultDeadline;
    }

    private class UploadResult
    {
        public string FileName { get; set; } = string.Empty;
        public string CategoryName { get; set; } = string.Empty;
    }

    private class AiUploadResp
    {
        public string StoredFileName { get; set; } = string.Empty;
        public string FullText { get; set; } = string.Empty;
    }

    private class ExtractTasksResponseLocal
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public List<ExtractedLocalTask> Tasks { get; set; } = new();
    }

    private class ExtractedLocalTask
    {
        public string Title { get; set; } = string.Empty;
        public string Deadline { get; set; } = string.Empty;
    }

    private class CreateTasksLocal
    {
        public string CategoryName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "OnTrack";
        public string FileName { get; set; } = string.Empty;
        public string StoredFileName { get; set; } = string.Empty;
        public List<CreateTaskItem> Tasks { get; set; } = new();
    }

    private class CreateTaskItem
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; }
    }
}
