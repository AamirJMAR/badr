@page "/deliverables"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="deliverables-page">
    <div class="page-header mb-4">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <div class="page-title-wrap">
                    <span class="page-title-icon">📄</span>
                    <div>
                        <h1 class="page-title mb-1">Livrables</h1>
                        <p class="page-subtitle mb-0">
                            Déposez un document pour l’enregistrer dans le registre des livrables ou lancer une analyse IA.
                        </p>
                    </div>
                </div>
            </div>

            <div class="header-actions">
                <button class="btn btn-outline-primary btn-sm" @onclick="GoToRegister">
                    📁 Voir le registre
                </button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 upload-card">
        <div class="card-body p-4">
            <div class="section-heading mb-4">
                <h5 class="fw-bold mb-1">Déposer un document</h5>
                <p class="text-muted small mb-0">
                    Chargez un fichier, choisissez l’action souhaitée puis validez.
                </p>
            </div>

            <div class="upload-zone mb-4">
                <div class="upload-zone-icon">⬆️</div>
                <div class="upload-zone-content">
                    <div class="upload-zone-title">Importer un fichier</div>
                    <div class="upload-zone-text">
                        PDF ou document de suivi à enregistrer dans le registre.
                    </div>
                </div>

                <div class="upload-input-wrap">
                    <InputFile OnChange="HandleFileSelected" class="upload-input" />
                </div>
            </div>

            @if (fileSelected)
            {
                <div class="selected-file-banner mb-4">
                    <div class="selected-file-icon">📎</div>
                    <div class="selected-file-info">
                        <div class="selected-file-label">Fichier sélectionné</div>
                        <div class="selected-file-name">@selectedFileName</div>
                    </div>
                    <span class="badge bg-success-subtle text-success-emphasis selected-badge">
                        Prêt
                    </span>
                </div>

                <div class="form-section mb-4">
                    <div class="form-section-title">Action après chargement</div>
                    <div class="form-section-subtitle">
                        Choisissez ce que vous souhaitez faire après l’import du document.
                    </div>

                    <div class="action-options mt-3">
                        <div class="action-option-item">
                            <input class="btn-check"
                                   type="radio"
                                   id="storeOnly"
                                   name="actionAfter"
                                   value="store"
                                   @onchange="SetAction"
                                   checked="@(selectedAction == "store")" />

                            <label class="action-tile" for="storeOnly">
                                <div class="action-tile-icon">💾</div>
                                <div class="action-tile-content">
                                    <div class="action-tile-title">Enregistrer uniquement</div>
                                    <div class="action-tile-text">
                                        Le document est ajouté au registre sans analyse IA.
                                    </div>
                                </div>
                            </label>
                        </div>

                        <div class="action-option-item">
                            <input class="btn-check"
                                   type="radio"
                                   id="analyzeOnly"
                                   name="actionAfter"
                                   value="analyze"
                                   @onchange="SetAction"
                                   checked="@(selectedAction == "analyze")" />

                            <label class="action-tile" for="analyzeOnly">
                                <div class="action-tile-icon">🤖</div>
                                <div class="action-tile-content">
                                    <div class="action-tile-title">Analyser uniquement</div>
                                    <div class="action-tile-text">
                                        Le fichier est analysé pour extraire les tâches, sans enregistrement.
                                    </div>
                                </div>
                            </label>
                        </div>

                        <div class="action-option-item">
                            <input class="btn-check"
                                   type="radio"
                                   id="storeAnalyze"
                                   name="actionAfter"
                                   value="store_analyze"
                                   @onchange="SetAction"
                                   checked="@(selectedAction == "store_analyze")" />

                            <label class="action-tile" for="storeAnalyze">
                                <div class="action-tile-icon">⚡</div>
                                <div class="action-tile-content">
                                    <div class="action-tile-title">Enregistrer + analyser</div>
                                    <div class="action-tile-text">
                                        Le document est sauvegardé puis les tâches sont extraites automatiquement.
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-section mb-4">
                    <div class="row g-3">
                        <div class="col-lg-8">
                            <label class="form-label fw-semibold">Projet</label>
                            <input class="form-control form-control-lg"
                                   placeholder="Nom du projet (optionnel — défaut : nom du fichier)"
                                   @bind="projectName" />
                            <div class="form-text">
                                Vous pouvez renommer le projet avant l’enregistrement.
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <label class="form-label fw-semibold">Mode sélectionné</label>
                            <div class="selected-action-box">
                                @if (selectedAction == "store")
                                {
                                    <span class="badge text-bg-primary fs-6">💾 Enregistrer uniquement</span>
                                }
                                else if (selectedAction == "analyze")
                                {
                                    <span class="badge text-bg-warning fs-6">🤖 Analyser uniquement</span>
                                }
                                else if (selectedAction == "store_analyze")
                                {
                                    <span class="badge text-bg-success fs-6">⚡ Enregistrer + analyser</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state-hint">
                    <div class="empty-state-icon">ℹ️</div>
                    <div>
                        <div class="empty-state-title">Aucun fichier sélectionné</div>
                        <div class="empty-state-text">
                            Commencez par choisir un document. Les options d’action apparaîtront ensuite automatiquement.
                        </div>
                    </div>
                </div>
            }

            <div class="action-bar mt-4">
                <button class="btn btn-primary btn-lg px-4"
                        @onclick="SaveFile"
                        disabled="@(!fileSelected || isSaving)">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Traitement en cours…</span>
                    }
                    else
                    {
                        @if (selectedAction == "analyze")
                        {
                            <span>🤖 Lancer l’analyse</span>
                        }
                        else if (selectedAction == "store_analyze")
                        {
                            <span>⚡ Enregistrer et analyser</span>
                        }
                        else
                        {
                            <span>💾 Enregistrer le fichier</span>
                        }
                    }
                </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-4 mb-0" role="alert">
                    <div class="fw-semibold mb-1">Une erreur est survenue</div>
                    <div>@errorMessage</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success mt-4 mb-0" role="alert">
                    <div class="fw-semibold mb-1">Opération réussie</div>
                    <div>@successMessage</div>

                    <div class="mt-3">
                        <button class="btn btn-sm btn-outline-success" @onclick="GoToRegister">
                            Voir le registre des livrables
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ✅ ANALYSIS RESULT MODAL (Editable) -->
<div class="modal fade" id="analysisModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold">📋 Analyse AI — Tâches extraites</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                @if (analysisLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border" role="status"></div>
                        <p class="mt-3 mb-0 text-muted">Extraction et analyse en cours…</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(analysisError))
                {
                    <div class="alert alert-danger">@analysisError</div>
                }
                else if (editableTasks != null)
                {
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Projet</label>
                            <input class="form-control" @bind="editableProject" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Client</label>
                            <input class="form-control" @bind="editableClient" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                        <div>
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => AddEditableTask()">
                                + Ajouter une tâche
                            </button>
                        </div>
                        <div class="text-muted small">
                            Vous pouvez modifier ou supprimer les tâches avant de les créer.
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Tâche</th>
                                    <th style="width: 180px;">Deadline</th>
                                    <th style="width: 120px;" class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < editableTasks.Count; i++)
                                {
                                    var taskIndex = i;
                                    <tr>
                                        <td>
                                            <input class="form-control form-control-sm" @bind="editableTasks[taskIndex].Title" />
                                        </td>
                                        <td>
                                            <input class="form-control form-control-sm"
                                                   @bind="editableTasks[taskIndex].Deadline"
                                                   placeholder="yyyy-MM-dd" />
                                        </td>
                                        <td class="text-center">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => RemoveEditableTask(taskIndex)">
                                                Supprimer
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button class="btn btn-success"
                        @onclick="CreateTasksFromAnalysisEditable"
                        disabled="@(editableTasks == null || editableTasks.Count == 0 || isCreatingTasks)">
                    @if (isCreatingTasks)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Création…</span>
                    }
                    else
                    {
                        <span>✅ Créer les tâches</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private IBrowserFile? uploadedFile;
    private bool fileSelected;
    private bool isSaving;
    private string selectedFileName = string.Empty;
    private string projectName = string.Empty;
    private string selectedAction = "store";
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        fileSelected = uploadedFile != null;
        selectedFileName = uploadedFile?.Name ?? string.Empty;
        projectName = Path.GetFileNameWithoutExtension(selectedFileName);
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    private void SetAction(ChangeEventArgs e)
    {
        selectedAction = e.Value?.ToString() ?? "store";
    }

    private async Task SaveFile()
    {
        if (uploadedFile == null)
            return;

        isSaving = true;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            // Build multipart content for the file
            var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(uploadedFile.OpenReadStream(20_000_000));
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                uploadedFile.ContentType ?? "application/pdf");
            content.Add(streamContent, "file", uploadedFile.Name);

            if (!string.IsNullOrWhiteSpace(projectName))
                content.Add(new StringContent(projectName.Trim()), "projectName");

            // Branch on selected action
            if (selectedAction == "store")
            {
                var response = await Http.PostAsync("api/deliverables/upload", content);
                if (!response.IsSuccessStatusCode)
                {
                    var errBody = await response.Content.ReadAsStringAsync();
                    errorMessage = string.IsNullOrWhiteSpace(errBody)
                        ? $"Échec de l'enregistrement : {response.ReasonPhrase}"
                        : $"Échec de l'enregistrement : {errBody}";
                    return;
                }

                var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                successMessage = result != null
                    ? $"Fichier « {result.FileName} » enregistré sous le projet « {result.ProjectName} »."
                    : "Fichier enregistré avec succès.";
            }
            else if (selectedAction == "analyze")
            {
                // Send to AI upload (extract text + store temp file on server)
                var aiUpload = await Http.PostAsync("api/ai/upload", content);
                if (!aiUpload.IsSuccessStatusCode)
                {
                    errorMessage = "Échec de l'analyse : impossible d'extraire le texte.";
                    return;
                }

                var uploadResp = await aiUpload.Content.ReadFromJsonAsync<AiUploadResp>();
                if (uploadResp == null)
                {
                    errorMessage = "Réponse d'analyse invalide.";
                    return;
                }

                // Call AI extract-tasks
                var extractResp = await Http.PostAsJsonAsync("api/ai/extract-tasks", new { Text = uploadResp.FullText });
                if (!extractResp.IsSuccessStatusCode)
                {
                    errorMessage = "L'analyse AI a échoué.";
                    return;
                }

                var tasks = await extractResp.Content.ReadFromJsonAsync<ExtractTasksResponseLocal>();
                successMessage = tasks != null
                    ? $"Analyse terminée — {tasks.Tasks?.Count ?? 0} tâches détectées."
                    : "Analyse terminée.";
            }
            else if (selectedAction == "store_analyze")
            {
                // First send to AI upload to extract text and get stored filename
                var aiUpload = await Http.PostAsync("api/ai/upload", content);
                if (!aiUpload.IsSuccessStatusCode)
                {
                    errorMessage = "Échec durant l'upload AI.";
                    return;
                }

                var uploadResp = await aiUpload.Content.ReadFromJsonAsync<AiUploadResp>();
                if (uploadResp == null)
                {
                    errorMessage = "Réponse d'upload AI invalide.";
                    return;
                }

                // Extract tasks
                var extractResp = await Http.PostAsJsonAsync("api/ai/extract-tasks", new { Text = uploadResp.FullText });
                if (!extractResp.IsSuccessStatusCode)
                {
                    errorMessage = "L'analyse AI a échoué.";
                    return;
                }

                var tasks = await extractResp.Content.ReadFromJsonAsync<ExtractTasksResponseLocal>();

                // Show modal with editable tasks
                errorMessage = string.Empty;
                successMessage = string.Empty;
                await ShowAnalysisModal(tasks, uploadResp);
                return; // Don't reset selection, modal is open for editing
            }

            // Reset selection on success
            uploadedFile = null;
            fileSelected = false;
            selectedFileName = string.Empty;
            projectName = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private static DateTime ParseDeadlineOrToday(string? d)
    {
        if (string.IsNullOrWhiteSpace(d)) return DateTime.Today;
        if (d == "TBD") return DateTime.Today;
        if (DateTime.TryParse(d, out var dt)) return dt;
        return DateTime.Today;
    }

    private void GoToRegister() => Navigation.NavigateTo("/deliverables-register");

    // ✅ AI ANALYSIS EDITABLE MODAL LOGIC
    private bool analysisLoading = false;
    private string analysisError = string.Empty;
    private List<EditableTask>? editableTasks;
    private string editableProject = string.Empty;
    private string editableClient = string.Empty;
    private bool isCreatingTasks = false;
    private string? tempStoredFileName; // Store the filename from AI upload for later use
    private AiUploadResp? lastAiUpload; // Store the AI upload response

    private async Task ShowAnalysisModal(ExtractTasksResponseLocal tasks, AiUploadResp uploadResp)
    {
        editableProject = tasks?.ProjectName ?? string.Empty;
        editableClient = tasks?.Client ?? string.Empty;
        editableTasks = (tasks?.Tasks ?? new()).Select(t => new EditableTask { Title = t.Title, Deadline = t.Deadline }).ToList();
        lastAiUpload = uploadResp;
        tempStoredFileName = uploadResp.StoredFileName;

        analysisError = string.Empty;
        analysisLoading = false;

        await JS.InvokeVoidAsync("bootstrapModal.show", "analysisModal");
    }

    private void AddEditableTask()
    {
        if (editableTasks != null)
        {
            editableTasks.Add(new EditableTask { Title = string.Empty, Deadline = "TBD" });
        }
    }

    private void RemoveEditableTask(int index)
    {
        if (editableTasks != null && index >= 0 && index < editableTasks.Count)
        {
            editableTasks.RemoveAt(index);
        }
    }

    private async Task CreateTasksFromAnalysisEditable()
    {
        if (editableTasks == null || editableTasks.Count == 0)
            return;

        isCreatingTasks = true;
        analysisError = string.Empty;

        try
        {
            var createPayload = new CreateTasksLocal
            {
                ProjectName = string.IsNullOrWhiteSpace(editableProject) ? $"Project-{DateTime.Now:yyyyMMdd}" : editableProject,
                Client = editableClient ?? string.Empty,
                Status = "Open",
                FileName = selectedFileName,
                StoredFileName = tempStoredFileName ?? string.Empty,
                Tasks = editableTasks.Select(t => new CreateTaskItem { Title = t.Title, Deadline = ParseDeadlineOrToday(t.Deadline) }).ToList()
            };

            var createResp = await Http.PostAsJsonAsync("api/deliverables/create-tasks", createPayload);
            if (!createResp.IsSuccessStatusCode)
            {
                analysisError = "Échec de la création des tâches.";
                return;
            }

            // Success - close modal and reset form
            await JS.InvokeVoidAsync("bootstrapModal.hide", "analysisModal");

            successMessage = $"Fichier et tâches enregistrés avec succès.";
            uploadedFile = null;
            fileSelected = false;
            selectedFileName = string.Empty;
            projectName = string.Empty;
            editableTasks = null;
            tempStoredFileName = null;
            lastAiUpload = null;
        }
        catch (Exception ex)
        {
            analysisError = ex.Message;
        }
        finally
        {
            isCreatingTasks = false;
        }
    }

    private class EditableTask
    {
        public string Title { get; set; } = string.Empty;
        public string Deadline { get; set; } = "TBD";
    }

    private class UploadResult
    {
        public int ProjectId { get; set; }
        public int DeliverableId { get; set; }
        public string FileName { get; set; } = string.Empty;
        public string ProjectName { get; set; } = string.Empty;
    }

    // Local DTOs for AI responses
    private class AiUploadResp
    {
        public string FileName { get; set; } = string.Empty;
        public string StoredFileName { get; set; } = string.Empty;
        public string FullText { get; set; } = string.Empty;
        public string Preview { get; set; } = string.Empty;
    }

    private class ExtractTasksResponseLocal
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public List<ExtractedLocalTask> Tasks { get; set; } = new();
    }

    private class ExtractedLocalTask
    {
        public string Title { get; set; } = string.Empty;
        public string Deadline { get; set; } = string.Empty;
    }

    private class CreateTasksLocal
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "OnTrack";
        public string FileName { get; set; } = string.Empty;
        public string FilePath { get; set; } = string.Empty;
        public string StoredFileName { get; set; } = string.Empty;
        public List<CreateTaskItem> Tasks { get; set; } = new();
    }

    private class CreateTaskItem
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; }
    }

    private class CreateResultLocal
    {
        public int ProjectId { get; set; }
        public int DeliverableId { get; set; }
    }
}