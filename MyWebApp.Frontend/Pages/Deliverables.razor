@page "/deliverables"
@inject HttpClient Http
@inject NavigationManager Navigation

<h1 class="fw-bold mb-1">Livrables</h1>
<p class="text-muted mb-4">
    Déposez un document pour l'enregistrer dans le registre des livrables. Aucune analyse IA n'est effectuée.
</p>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h5 class="fw-bold mb-3">📄 Déposer un document</h5>

        <InputFile OnChange="HandleFileSelected" class="form-control" />

        @if (fileSelected)
        {
            <p class="text-muted small mt-2 mb-0">Fichier sélectionné : <strong>@selectedFileName</strong></p>
        }

        <div class="mt-3">
            <label class="form-label">Projet</label>
            <input class="form-control"
                   placeholder="Nom du projet (optionnel — défaut : nom du fichier)"
                   @bind="projectName" />
        </div>

        <button class="btn btn-primary mt-3"
                @onclick="SaveFile"
                disabled="@(!fileSelected || isSaving)">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Enregistrement…</span>
            }
            else
            {
                <span>💾 Enregistrer le fichier</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success mt-3 mb-0">
                @successMessage
                <div class="mt-2">
                    <button class="btn btn-sm btn-outline-success" @onclick="GoToRegister">
                        Voir le registre des livrables
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IBrowserFile? uploadedFile;
    private bool fileSelected;
    private bool isSaving;
    private string selectedFileName = string.Empty;
    private string projectName = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        fileSelected = uploadedFile != null;
        selectedFileName = uploadedFile?.Name ?? string.Empty;
        projectName = Path.GetFileNameWithoutExtension(selectedFileName);
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    private async Task SaveFile()
    {
        if (uploadedFile == null)
            return;

        isSaving = true;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(uploadedFile.OpenReadStream(20_000_000));
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                uploadedFile.ContentType ?? "application/octet-stream");
            content.Add(streamContent, "file", uploadedFile.Name);

            if (!string.IsNullOrWhiteSpace(projectName))
                content.Add(new StringContent(projectName.Trim()), "projectName");

            var response = await Http.PostAsync("api/deliverables/upload", content);

            if (!response.IsSuccessStatusCode)
            {
                var errBody = await response.Content.ReadAsStringAsync();
                errorMessage = string.IsNullOrWhiteSpace(errBody)
                    ? $"Échec de l'enregistrement : {response.ReasonPhrase}"
                    : $"Échec de l'enregistrement : {errBody}";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<UploadResult>();
            successMessage = result != null
                ? $"Fichier « {result.FileName} » enregistré sous le projet « {result.ProjectName} »."
                : "Fichier enregistré avec succès.";

            uploadedFile = null;
            fileSelected = false;
            selectedFileName = string.Empty;
            projectName = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoToRegister() => Navigation.NavigateTo("/deliverables-register");

    private class UploadResult
    {
        public int ProjectId { get; set; }
        public int DeliverableId { get; set; }
        public string FileName { get; set; } = string.Empty;
        public string ProjectName { get; set; } = string.Empty;
    }
}
