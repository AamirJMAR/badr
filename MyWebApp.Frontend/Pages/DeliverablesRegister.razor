@page "/deliverables-register"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<h1 class="fw-bold mb-1">📁 Deliverables Register</h1>
<p class="text-muted mb-4">
    History of uploaded project documents and generated tasks.
</p>

@if (deliverables == null)
{
    <div class="text-center text-muted">
        <div class="spinner-border" role="status"></div>
        <p class="mt-2">Loading deliverables...</p>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="d-flex align-items-center justify-content-between p-3 border-bottom bg-light">
                <div>
                    <button class="btn btn-sm btn-primary me-2"
                            disabled="@(!selectedDeliverables.Any())"
                            @onclick="BulkViewSelected">
                        👁️ View selected
                    </button>
                    <button class="btn btn-sm btn-outline-secondary me-2"
                            disabled="@(!selectedDeliverables.Any())"
                            @onclick="BulkDownloadSelected">
                        ⬇️ Download selected
                    </button>
                    <button class="btn btn-sm btn-outline-danger"
                            disabled="@(!selectedDeliverables.Any())"
                            @onclick="OpenBulkDeleteModal">
                        🗑️ Delete selected
                    </button>
                </div>
                <div class="text-muted small">
                    @selectedDeliverables.Count selected
                </div>
            </div>

            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;">
                            <input type="checkbox"
                                   @onchange="ToggleSelectAll"
                                   checked="@((deliverables != null) && deliverables.All(d => selectedDeliverables.Contains(d.Id)))" />
                        </th>
                        <th>File</th>
                        <th>Project</th>
                        <th>Upload Date</th>
                        <th class="text-center">Tasks</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in deliverables)
                    {
                        <tr>
                            <td>
                                <input type="checkbox"
                                       class="form-check-input"
                                       checked="@selectedDeliverables.Contains(d.Id)"
                                       @onchange="e => ToggleSelection(d.Id, e)"
                                       @onclick:stopPropagation />
                            </td>

                            <!-- FILE (clic pour preview) -->
                            <td style="cursor:pointer"
                                @onclick="() => PreviewFile(d.Id)">
                                <strong>@d.FileName</strong>
                            </td>

                            <!-- PROJECT -->
                            <td>
                                <span class="badge bg-primary">
                                    @d.ProjectName
                                </span>
                            </td>

                            <!-- DATE -->
                            <td>
                                @d.UploadDate.ToString("dd MMM yyyy")
                            </td>

                            <!-- TASK COUNT -->
                            <td class="text-center">
                                <span class="badge bg-success">
                                    @d.TaskCount
                                </span>
                            </td>

                            <!-- ACTIONS -->
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm">

                                    <!-- DOWNLOAD -->
                                    <a class="btn btn-outline-secondary"
                                       href="http://localhost:5115/api/deliverables/download/@d.Id"
                                       target="_blank"
                                       @onclick:stopPropagation>
                                        ⬇️ Download
                                    </a>

                                    <!-- DELETE -->
                                    <button class="btn btn-outline-danger"
                                            @onclick:stopPropagation
                                            @onclick="() => OpenDeleteModal(d.Id)">
                                        🗑️ Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ✅ CONFIRM DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(isBulkDelete ? "Delete selected deliverables" : "Delete deliverable")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>
                    @if (isBulkDelete)
                    {
                        <text>Are you sure you want to delete the selected deliverables?</text>
                    }
                    else
                    {
                        <text>Are you sure you want to delete this deliverable?</text>
                    }
                </p>
                <p class="text-danger mb-0">
                    This will also delete all generated tasks and the uploaded file.
                </p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-danger" @onclick="ConfirmDelete">
                    🗑️ Delete
                </button>
            </div>
        </div>
    </div>
</div>

@code {

    private List<DeliverableRow>? deliverables;
    private int deliverableToDeleteId;
    private HashSet<int> selectedDeliverables = new();
    private bool isBulkDelete = false;

    protected override async Task OnInitializedAsync()
    {
        await ReloadDeliverables();
    }

    private async Task ReloadDeliverables()
    {
        deliverables = await Http.GetFromJsonAsync<List<DeliverableRow>>(
            "api/deliverables/register");
        selectedDeliverables.Clear();
    }

    private void ToggleSelection(int id, ChangeEventArgs e)
    {
        var selected = e.Value as bool? == true;
        if (selected)
            selectedDeliverables.Add(id);
        else
            selectedDeliverables.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var selected = e.Value as bool? == true;
        if (!selected)
        {
            selectedDeliverables.Clear();
            return;
        }

        if (deliverables != null)
        {
            selectedDeliverables = deliverables.Select(d => d.Id).ToHashSet();
        }
    }

    private async Task BulkViewSelected()
    {
        var ids = string.Join(",", selectedDeliverables.OrderBy(id => id));
        var url = $"http://localhost:5115/api/deliverables/bulk-view?ids={ids}";

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task BulkDownloadSelected()
    {
        var ids = string.Join(",", selectedDeliverables.OrderBy(id => id));
        var url = $"http://localhost:5115/api/deliverables/bulk-download?ids={ids}";

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    // ✅ PREVIEW PDF
    private async Task PreviewFile(int id)
    {
        await JS.InvokeVoidAsync(
            "open",
            $"http://localhost:5115/api/deliverables/view/{id}",
            "_blank"
        );
    }

    // ✅ OPEN DELETE MODAL
    private async Task OpenDeleteModal(int deliverableId)
    {
        isBulkDelete = false;
        deliverableToDeleteId = deliverableId;
        await JS.InvokeVoidAsync("bootstrapModal.show", "deleteModal");
    }

    private async Task OpenBulkDeleteModal()
    {
        isBulkDelete = true;
        await JS.InvokeVoidAsync("bootstrapModal.show", "deleteModal");
    }

    // ✅ CONFIRM DELETE
    private async Task ConfirmDelete()
    {
        if (isBulkDelete)
        {
            var deleteTasks = selectedDeliverables
                .Select(id => Http.DeleteAsync($"api/deliverables/{id}"));

            await Task.WhenAll(deleteTasks);
            selectedDeliverables.Clear();
        }
        else
        {
            await Http.DeleteAsync($"api/deliverables/{deliverableToDeleteId}");
        }

        await ReloadDeliverables();
        await JS.InvokeVoidAsync("bootstrapModal.hide", "deleteModal");
    }

    // ✅ DTO
    private class DeliverableRow
    {
        public int Id { get; set; }
        public string FileName { get; set; } = "";
        public string ProjectName { get; set; } = "";
        public DateTime UploadDate { get; set; }
        public int TaskCount { get; set; }
    }
}
