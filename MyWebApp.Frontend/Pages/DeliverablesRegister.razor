@page "/deliverables-register"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="deliverables-register-page">
    <div class="page-header mb-4">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <div class="page-title-wrap">
                    <span class="page-title-icon">📁</span>
                    <div>
                        <h1 class="page-title mb-1">Deliverables Register</h1>
                        <p class="page-subtitle mb-0">
                            History of uploaded project documents and generated tasks.
                        </p>
                    </div>
                </div>
            </div>

            <div class="header-actions">
                <button class="btn btn-primary btn-sm" @onclick='() => Navigation.NavigateTo("/deliverables")'>
                    ⬆️ Upload new file
                </button>
            </div>
        </div>
    </div>

    @if (deliverables == null)
    {
        <div class="card shadow-sm border-0 loading-card">
            <div class="card-body text-center py-5">
                <div class="loading-icon mb-3">📄</div>
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0 text-muted">Loading deliverables...</p>
            </div>
        </div>
    }
    else if (!deliverables.Any())
    {
        <div class="card shadow-sm border-0 empty-card">
            <div class="card-body py-5">
                <div class="empty-state">
                    <div class="empty-state-icon">📂</div>
                    <div class="empty-state-content">
                        <h5 class="empty-state-title mb-2">No deliverables yet</h5>
                        <p class="empty-state-text mb-3">
                            No uploaded documents were found in the register. Start by uploading your first file.
                        </p>
                        <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/deliverables")'>
                            ⬆️ Upload a deliverable
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 register-card">
            <div class="card-body p-0">
                <div class="toolbar">
                    <div class="toolbar-left">
    <button class="btn btn-primary btn-sm"
            disabled="@(!selectedDeliverables.Any())"
            @onclick="BulkViewSelected">
        👁️ View selected
    </button>

    <button class="btn btn-outline-primary btn-sm"
disabled="@(!selectedDeliverables.Any() || isAnalyzingSelected)"
            @onclick="AnalyzeSelected">
        @if (isAnalyzingSelected)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
            <span>Analysing...</span>
        }
        else
        {
            <span>🤖 Analyse selected</span>
        }
    </button>

    <button class="btn btn-outline-secondary btn-sm"
            disabled="@(!selectedDeliverables.Any())"
            @onclick="BulkDownloadSelected">
        ⬇️ Download selected
    </button>

    <button class="btn btn-outline-danger btn-sm"
            disabled="@(!selectedDeliverables.Any())"
            @onclick="OpenBulkDeleteModal">
        🗑️ Delete selected
    </button>
</div>


                    <div class="toolbar-right">
                        <span class="selection-counter">@selectedDeliverables.Count selected</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0 register-table">
                        <thead>
                            <tr>
                                <th style="width: 44px;">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           @onchange="ToggleSelectAll"
                                           checked="@((deliverables != null) && deliverables.All(d => selectedDeliverables.Contains(d.Id)))" />
                                </th>
                                <th>File</th>
                                <th>Project</th>
                                <th>Upload Date</th>
                                <th class="text-center">Tasks</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in deliverables)
                            {
                                <tr class="register-row">
                                    <td>
                                        <input type="checkbox"
                                               class="form-check-input"
                                               checked="@selectedDeliverables.Contains(d.Id)"
                                               @onchange="e => ToggleSelection(d.Id, e)"
                                               @onclick:stopPropagation />
                                    </td>

                                    <td>
                                        <button class="file-link-btn"
                                                @onclick="() => PreviewFile(d.Id)">
                                            <span class="file-link-name">@d.FileName</span>
                                        </button>
                                    </td>

                                    <td>
                                        <span class="badge text-bg-primary project-badge">
                                            @d.ProjectName
                                        </span>
                                    </td>

                                    <td>
                                        <span class="date-text">
                                            @d.UploadDate.ToString("dd MMM yyyy")
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <span class="badge text-bg-success task-badge">
                                            @d.TaskCount
                                        </span>
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm action-group">
                                            
<button class="btn btn-outline-primary"
        title="Analyse AI (extraction + analyse en 1 clic)"
        disabled="@analyzingDeliverableIds.Contains(d.Id)"
        @onclick:stopPropagation
        @onclick="() => AnalyzeDeliverable(d.Id)">
    @if (analyzingDeliverableIds.Contains(d.Id))
    {
        <span class="spinner-border spinner-border-sm me-2"></span>
        <span>Analysing...</span>
    }
    else
    {
        <span>🤖 Analyse</span>
    }
</button>


                                            <a class="btn btn-outline-secondary"
                                               href="http://localhost:5115/api/deliverables/download/@d.Id"
                                               target="_blank"
                                               @onclick:stopPropagation>
                                                ⬇️ Download
                                            </a>

                                            <button class="btn btn-outline-danger"
                                                    @onclick:stopPropagation
                                                    @onclick="() => OpenDeleteModal(d.Id)">
                                                🗑️ Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- ✅ CONFIRM DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow app-modal">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold">
                    @(isBulkDelete ? "Delete selected deliverables" : "Delete deliverable")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body pt-0">
                <div class="warning-box">
                    <div class="warning-box-icon">⚠️</div>
                    <div>
                        <p class="mb-2">
                            @if (isBulkDelete)
                            {
                                <text>Are you sure you want to delete the selected deliverables?</text>
                            }
                            else
                            {
                                <text>Are you sure you want to delete this deliverable?</text>
                            }
                        </p>
                        <p class="text-danger mb-0 fw-semibold">
                            This will also delete all generated tasks and the uploaded file.
                        </p>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-danger" @onclick="ConfirmDelete">
                    🗑️ Delete
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ✅ ANALYSIS RESULT MODAL (Editable) -->
<div class="modal fade" id="analysisModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow app-modal">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold">📋 Analyse AI — Tâches extraites</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                @if (analysisLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-3 mb-0 text-muted">Extraction et analyse en cours…</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(analysisError))
                {
                    <div class="alert alert-danger">@analysisError</div>
                }
                else if (editableTasks != null)
                {
                    <div class="analysis-top-grid mb-4">
                        <div>
                            <label class="form-label fw-semibold">Projet</label>
                            <input class="form-control" @bind="editableProject" />
                        </div>
                        <div>
                            <label class="form-label fw-semibold">Client</label>
                            <input class="form-control" @bind="editableClient" />
                        </div>
                    </div>

                    <div class="analysis-toolbar mb-3">
                        <div>
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => AddEditableTask()">
                                + Ajouter une tâche
                            </button>
                        </div>
                        <div class="text-muted small">
                            Vous pouvez supprimer les tâches avant de les créer.
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle analysis-table">
                            <thead>
                                <tr>
                                    <th>Tâche</th>
                                    <th style="width: 180px;">Deadline</th>
                                    <th style="width: 120px;" class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < editableTasks.Count; i++)
                                {
                                    var taskIndex = i;
                                    <tr>
                                        <td>
                                            <input class="form-control form-control-sm" @bind="editableTasks[taskIndex].Title" />
                                        </td>
                                        <td>
                                            <input class="form-control form-control-sm"
                                                   @bind="editableTasks[taskIndex].Deadline"
                                                   placeholder="yyyy-MM-dd" />
                                        </td>
                                        <td class="text-center">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => RemoveEditableTask(taskIndex)">
                                                Supprimer
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button class="btn btn-success"
                        @onclick="CreateTasksFromAnalysisEditable"
                        disabled="@(editableTasks == null || editableTasks.Count == 0 || isCreatingTasks)">
                    @if (isCreatingTasks)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Création…</span>
                    }
                    else
                    {
                        <span>✅ Créer les tâches</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@code {

    private List<DeliverableRow>? deliverables;
    private int deliverableToDeleteId;
    private HashSet<int> analyzingDeliverableIds = new();
private bool isAnalyzingSelected = false;

    private HashSet<int> selectedDeliverables = new();
    private bool isBulkDelete = false;

    protected override async Task OnInitializedAsync()
    {
        await ReloadDeliverables();
    }

    private async Task ReloadDeliverables()
    {
        deliverables = await Http.GetFromJsonAsync<List<DeliverableRow>>(
            "api/deliverables/register");
        selectedDeliverables.Clear();
    }

    private void ToggleSelection(int id, ChangeEventArgs e)
    {
        var selected = e.Value as bool? == true;
        if (selected)
            selectedDeliverables.Add(id);
        else
            selectedDeliverables.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var selected = e.Value as bool? == true;
        if (!selected)
        {
            selectedDeliverables.Clear();
            return;
        }

        if (deliverables != null)
        {
            selectedDeliverables = deliverables.Select(d => d.Id).ToHashSet();
        }
    }

    private async Task BulkViewSelected()
    {
        var ids = string.Join(",", selectedDeliverables.OrderBy(id => id));
        var url = $"http://localhost:5115/api/deliverables/bulk-view?ids={ids}";

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task BulkDownloadSelected()
    {
        var ids = string.Join(",", selectedDeliverables.OrderBy(id => id));
        var url = $"http://localhost:5115/api/deliverables/bulk-download?ids={ids}";

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    // ✅ PREVIEW PDF
    private async Task PreviewFile(int id)
    {
        await JS.InvokeVoidAsync(
            "open",
            $"http://localhost:5115/api/deliverables/view/{id}",
            "_blank"
        );
    }

    // ✅ OPEN DELETE MODAL
    private async Task OpenDeleteModal(int deliverableId)
    {
        isBulkDelete = false;
        deliverableToDeleteId = deliverableId;
        await JS.InvokeVoidAsync("bootstrapModal.show", "deleteModal");
    }

    private async Task OpenBulkDeleteModal()
    {
        isBulkDelete = true;
        await JS.InvokeVoidAsync("bootstrapModal.show", "deleteModal");
    }

    // ✅ CONFIRM DELETE
    private async Task ConfirmDelete()
    {
        if (isBulkDelete)
        {
            var deleteTasks = selectedDeliverables
                .Select(id => Http.DeleteAsync($"api/deliverables/{id}"));

            await Task.WhenAll(deleteTasks);
            selectedDeliverables.Clear();
        }
        else
        {
            await Http.DeleteAsync($"api/deliverables/{deliverableToDeleteId}");
        }

        await ReloadDeliverables();
        await JS.InvokeVoidAsync("bootstrapModal.hide", "deleteModal");
    }

    // ✅ AI ANALYSIS (single click: extract + analyze) - EDITABLE
    private bool analysisLoading = false;
    private string analysisError = string.Empty;
    private List<EditableTask>? editableTasks;
    private string editableProject = string.Empty;
    private string editableClient = string.Empty;
    private int analysisDeliverableId;
    private bool isCreatingTasks = false;

    private async Task AnalyzeDeliverable(int id)
{
    if (analyzingDeliverableIds.Contains(id))
        return;

    analyzingDeliverableIds.Add(id);
    analysisLoading = true;
    analysisError = string.Empty;
    editableTasks = null;
    analysisDeliverableId = id;

    StateHasChanged();

    try
    {
        // get the file bytes from download endpoint
        var fileResp = await Http.GetAsync($"api/deliverables/download/{id}");
        if (!fileResp.IsSuccessStatusCode)
        {
            analysisError = "Impossible de récupérer le fichier pour analyse.";
            return;
        }

        var stream = await fileResp.Content.ReadAsStreamAsync();

        var content = new MultipartFormDataContent();
        var streamContent = new StreamContent(stream);
        streamContent.Headers.ContentType = fileResp.Content.Headers.ContentType
            ?? new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");

        // find filename from deliverables list if available
        var row = deliverables?.FirstOrDefault(d => d.Id == id);
        var fileName = row?.FileName ?? $"file-{id}.pdf";
        content.Add(streamContent, "file", fileName);

        // POST to AI upload to extract text
        var aiUpload = await Http.PostAsync("api/ai/upload", content);
        if (!aiUpload.IsSuccessStatusCode)
        {
            analysisError = "Échec de l'extraction du fichier.";
            return;
        }

        var uploadResp = await aiUpload.Content.ReadFromJsonAsync<AiUploadResp>();
        if (uploadResp == null)
        {
            analysisError = "Réponse d'extraction invalide.";
            return;
        }

        // Call extract-tasks
        var extractResp = await Http.PostAsJsonAsync("api/ai/extract-tasks", new { Text = uploadResp.FullText });
        if (!extractResp.IsSuccessStatusCode)
        {
            analysisError = "L'analyse AI a échoué.";
            return;
        }

        var analysisResult = await extractResp.Content.ReadFromJsonAsync<ExtractTasksResponseLocal>();

        // Set editable tasks
        editableProject = analysisResult?.ProjectName ?? string.Empty;
        editableClient = analysisResult?.Client ?? string.Empty;
        editableTasks = (analysisResult?.Tasks ?? new())
            .Select(t => new EditableTask { Title = t.Title, Deadline = t.Deadline })
            .ToList();

        await JS.InvokeVoidAsync("bootstrapModal.show", "analysisModal");
    }
    catch (Exception ex)
    {
        analysisError = ex.Message;
    }
    finally
    {
        analysisLoading = false;
        analyzingDeliverableIds.Remove(id);
        StateHasChanged();
    }
}

    private void AddEditableTask()
    {
        if (editableTasks != null)
        {
            editableTasks.Add(new EditableTask { Title = string.Empty, Deadline = "TBD" });
        }
    }

    private void RemoveEditableTask(int index)
    {
        if (editableTasks != null && index >= 0 && index < editableTasks.Count)
        {
            editableTasks.RemoveAt(index);
        }
    }

    private async Task CreateTasksFromAnalysisEditable()
    {
        if (editableTasks == null || editableTasks.Count == 0)
            return;

        isCreatingTasks = true;
        analysisError = string.Empty;

        try
        {
            // build create payload
            var payload = new CreateTasksLocal
            {
                ProjectName = string.IsNullOrWhiteSpace(editableProject) ? $"Project-{DateTime.Now:yyyyMMdd}" : editableProject,
                Client = editableClient ?? string.Empty,
                Status = "Open",
                FileName = deliverables?.FirstOrDefault(d => d.Id == analysisDeliverableId)?.FileName ?? string.Empty,
                StoredFileName = string.Empty, // using already-stored file in DB
                Tasks = editableTasks.Select(t => new CreateTaskItem { Title = t.Title, Deadline = ParseDeadlineOrToday(t.Deadline) }).ToList()
            };

            var resp = await Http.PostAsJsonAsync("api/deliverables/create-tasks", payload);
            if (!resp.IsSuccessStatusCode)
            {
                analysisError = "Échec lors de la création des tâches.";
                return;
            }

            await JS.InvokeVoidAsync("bootstrapModal.hide", "analysisModal");
            editableTasks = null;
            await ReloadDeliverables();
        }
        catch (Exception ex)
        {
            analysisError = ex.Message;
        }
        finally
        {
            isCreatingTasks = false;
        }
    }

    private class EditableTask
    {
        public string Title { get; set; } = string.Empty;
        public string Deadline { get; set; } = "TBD";
    }

    // ✅ DTO
    private class DeliverableRow
    {
        public int Id { get; set; }
        public string FileName { get; set; } = "";
        public string ProjectName { get; set; } = "";
        public DateTime UploadDate { get; set; }
        public int TaskCount { get; set; }
    }

    // Local DTOs reused for AI interactions
    private class AiUploadResp
    {
        public string FileName { get; set; } = string.Empty;
        public string StoredFileName { get; set; } = string.Empty;
        public string FullText { get; set; } = string.Empty;
        public string Preview { get; set; } = string.Empty;
    }

    private class ExtractTasksResponseLocal
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public List<ExtractedLocalTask> Tasks { get; set; } = new();
    }

    private class ExtractedLocalTask
    {
        public string Title { get; set; } = string.Empty;
        public string Deadline { get; set; } = string.Empty;
    }

    private class CreateTasksLocal
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "OnTrack";
        public string FileName { get; set; } = string.Empty;
        public string FilePath { get; set; } = string.Empty;
        public string StoredFileName { get; set; } = string.Empty;
        public List<CreateTaskItem> Tasks { get; set; } = new();
    }

    private class CreateTaskItem
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; }
    }

    private static DateTime ParseDeadlineOrToday(string? d)
    {
        if (string.IsNullOrWhiteSpace(d)) return DateTime.Today;
        if (d == "TBD") return DateTime.Today;
        if (DateTime.TryParse(d, out var dt)) return dt;
        return DateTime.Today;
    }
private async Task AnalyzeSelected()
{
    if (!selectedDeliverables.Any())
        return;

    isAnalyzingSelected = true;
    StateHasChanged();

    try
    {
        var id = selectedDeliverables.First();
        await AnalyzeDeliverable(id);
    }
    finally
    {
        isAnalyzingSelected = false;
        StateHasChanged();
    }
}

}
