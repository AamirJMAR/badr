@page "/deliverables-register"
@using MyWebApp.Frontend.Constants
@using MyWebApp.Frontend.Helpers
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="pmo-page deliverables-register-page">
    <div class="page-header mb-4">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <div class="page-title-wrap">
                    <span class="page-title-icon">📁</span>
                    <div>
                        <h1 class="page-title mb-1">Deliverables Register</h1>
                        <p class="page-subtitle mb-0">
                            History of uploaded documents and generated tasks.
                        </p>
                    </div>
                </div>
            </div>

            <div class="header-actions">
                <button class="btn btn-primary btn-sm" @onclick='() => Navigation.NavigateTo("/deliverables")'>
                    ⬆️ Upload new file
                </button>
            </div>
        </div>
    </div>

    @if (deliverables == null)
    {
        <div class="card shadow-sm border-0 loading-card">
            <div class="card-body text-center py-5">
                <div class="loading-icon mb-3">📄</div>
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0 text-muted">Loading deliverables...</p>
            </div>
        </div>
    }
    else if (!deliverables.Any())
    {
        <div class="card shadow-sm border-0 empty-card">
            <div class="card-body py-5">
                <div class="empty-state">
                    <div class="empty-state-icon">📂</div>
                    <div class="empty-state-content">
                        <h5 class="empty-state-title mb-2">No deliverables yet</h5>
                        <p class="empty-state-text mb-3">
                            No uploaded documents were found in the register. Start by uploading your first file.
                        </p>
                        <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/deliverables")'>
                            ⬆️ Upload a deliverable
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 register-card">
            <div class="card-body p-0">
                <div class="toolbar">
                    <div class="toolbar-left">
                        <button class="btn btn-primary btn-sm"
                                disabled="@(!selectedDeliverables.Any())"
                                @onclick="BulkViewSelected">
                            👁️ View selected
                        </button>

                        <button class="btn btn-outline-primary btn-sm"
                                disabled="@(!selectedDeliverables.Any() || isAnalyzingSelected)"
                                @onclick="AnalyzeSelected">
                            @if (isAnalyzingSelected)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Analysing...</span>
                            }
                            else
                            {
                                <span>🤖 Analyse selected</span>
                            }
                        </button>

                        <button class="btn btn-outline-secondary btn-sm"
                                disabled="@(!selectedDeliverables.Any())"
                                @onclick="BulkDownloadSelected">
                            ⬇️ Download selected
                        </button>

                        <button class="btn btn-outline-danger btn-sm"
                                disabled="@(!selectedDeliverables.Any())"
                                @onclick="OpenBulkDeleteModal">
                            🗑️ Delete selected
                        </button>
                    </div>

                    <div class="toolbar-right">
                        <span class="selection-counter">@selectedDeliverables.Count selected</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0 register-table">
                        <thead>
                            <tr>
                                <th style="width: 44px;">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           @onchange="ToggleSelectAll"
                                           checked="@((deliverables != null) && deliverables.All(d => selectedDeliverables.Contains(d.Id)))" />
                                </th>
                                <th>File</th>
                                <th>Category</th>
                                <th>Upload Date</th>
                                <th class="text-center">Tasks</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in deliverables)
                            {
                                <tr class="register-row">
                                    <td>
                                        <input type="checkbox"
                                               class="form-check-input"
                                               checked="@selectedDeliverables.Contains(d.Id)"
                                               @onchange="e => ToggleSelection(d.Id, e)"
                                               @onclick:stopPropagation />
                                    </td>

                                    <td>
                                        <button class="file-link-btn"
                                                @onclick="() => PreviewFile(d.Id)">
                                            <span class="file-link-name">@d.FileName</span>
                                        </button>
                                    </td>

                                    <td>
                                        <span class="badge text-bg-primary project-badge">
                                            @d.CategoryName
                                        </span>
                                    </td>

                                    <td>
                                        <span class="date-text">
                                            @d.UploadDate.ToString("dd MMM yyyy")
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <span class="badge text-bg-success task-badge">
                                            @d.TaskCount
                                        </span>
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm action-group">
                                            <button class="btn btn-outline-primary"
                                                    title="AI analysis"
                                                    disabled="@analyzingDeliverableIds.Contains(d.Id)"
                                                    @onclick:stopPropagation
                                                    @onclick="() => AnalyzeSingle(d.Id)">
                                                @if (analyzingDeliverableIds.Contains(d.Id))
                                                {
                                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                                    <span>Analysing...</span>
                                                }
                                                else
                                                {
                                                    <span>🤖 Analyse</span>
                                                }
                                            </button>

                                            <a class="btn btn-outline-secondary"
                                               href="http://localhost:5115/api/deliverables/download/@d.Id"
                                               target="_blank"
                                               @onclick:stopPropagation>
                                                ⬇️ Download
                                            </a>

                                            <button class="btn btn-outline-danger"
                                                    @onclick:stopPropagation
                                                    @onclick="() => OpenDeleteModal(d.Id)">
                                                🗑️ Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow app-modal">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold">
                    @(isBulkDelete ? "Delete selected deliverables" : "Delete deliverable")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body pt-0">
                <div class="warning-box">
                    <div class="warning-box-icon">⚠️</div>
                    <div>
                        <p class="mb-2">
                            @if (isBulkDelete)
                            {
                                <text>Are you sure you want to delete the selected deliverables?</text>
                            }
                            else
                            {
                                <text>Are you sure you want to delete this deliverable?</text>
                            }
                        </p>
                        <p class="text-danger mb-0 fw-semibold">
                            This will also delete all generated tasks and the uploaded file.
                        </p>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">🗑️ Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- AI ANALYSIS MODAL (bulk queue) -->
@if (showAnalysisModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow app-modal">
                <div class="modal-header bg-light border-0">
                    <h5 class="modal-title fw-bold">
                        🤖 AI Analysis — @CurrentReviewFileName
                        @if (bulkReviewItems.Count > 1)
                        {
                            <span class="badge bg-secondary ms-2">@BulkProgressLabel</span>
                        }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelAnalysisReview" disabled="@isCreatingTasks"></button>
                </div>

                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(analysisError))
                    {
                        <div class="alert alert-danger">@analysisError</div>
                    }
                    else if (editableTasks != null)
                    {
                        <div class="analysis-top-grid mb-4">
                            <div>
                                <label class="form-label fw-semibold">Category</label>
                                <select class="form-select" @bind="editableCategoryName" disabled="@isCreatingTasks">
                                    @foreach (var cat in CategoryConstants.FixedCategories)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="form-label fw-semibold">Client</label>
                                <input class="form-control" @bind="editableClient" disabled="@isCreatingTasks" />
                            </div>
                        </div>

                        <div class="analysis-toolbar mb-3">
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddEditableTask" disabled="@isCreatingTasks">
                                + Add task
                            </button>
                            <span class="text-muted small ms-2">Edit or remove tasks before creating.</span>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle analysis-table">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th style="width: 180px;">Deadline</th>
                                        <th style="width: 120px;" class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < editableTasks.Count; i++)
                                    {
                                        var taskIndex = i;
                                        <tr>
                                            <td>
                                                <input class="form-control form-control-sm" @bind="editableTasks[taskIndex].Title" disabled="@isCreatingTasks" />
                                            </td>
                                            <td>
                                                <input type="date" class="form-control form-control-sm"
                                                       @bind-value="editableTasks[taskIndex].Deadline"
                                                       @bind-value:format="yyyy-MM-dd"
                                                       disabled="@isCreatingTasks" />
                                            </td>
                                            <td class="text-center">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => RemoveEditableTask(taskIndex)"
                                                        disabled="@isCreatingTasks">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-secondary" @onclick="CancelAnalysisReview" disabled="@isCreatingTasks">Cancel</button>
                    @if (HasNextReviewItem)
                    {
                        <button class="btn btn-outline-secondary" @onclick="SkipCurrentReview" disabled="@isCreatingTasks">Skip</button>
                    }
                    <button class="btn btn-success"
                            @onclick="CreateTasksFromAnalysisEditable"
                            disabled="@(editableTasks == null || editableTasks.Count == 0 || isCreatingTasks)">
                        @if (isCreatingTasks)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <span>✅ Create tasks</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<DeliverableRow>? deliverables;
    private int deliverableToDeleteId;
    private HashSet<int> analyzingDeliverableIds = new();
    private bool isAnalyzingSelected;
    private HashSet<int> selectedDeliverables = new();
    private bool isBulkDelete;

    private bool showAnalysisModal;
    private List<BulkDeliverableReviewItem> bulkReviewItems = new();
    private int bulkReviewIndex;
    private string analysisError = string.Empty;
    private List<EditableTask>? editableTasks;
    private string editableCategoryName = CategoryConstants.DefaultCategory;
    private string editableClient = string.Empty;
    private bool isCreatingTasks;

    private bool HasNextReviewItem => bulkReviewIndex < bulkReviewItems.Count - 1;
    private string? BulkProgressLabel => bulkReviewItems.Count > 1
        ? $"{bulkReviewIndex + 1} / {bulkReviewItems.Count}"
        : null;
    private string CurrentReviewFileName =>
        bulkReviewItems.ElementAtOrDefault(bulkReviewIndex)?.FileName ?? "Deliverable";

    protected override async Task OnInitializedAsync()
    {
        await ReloadDeliverables();
    }

    private async Task ReloadDeliverables()
    {
        deliverables = await Http.GetFromJsonAsync<List<DeliverableRow>>("api/deliverables/register");
        selectedDeliverables.Clear();
    }

    private void ToggleSelection(int id, ChangeEventArgs e)
    {
        var selected = e.Value as bool? == true;
        if (selected) selectedDeliverables.Add(id);
        else selectedDeliverables.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var selected = e.Value as bool? == true;
        if (!selected)
        {
            selectedDeliverables.Clear();
            return;
        }

        if (deliverables != null)
            selectedDeliverables = deliverables.Select(d => d.Id).ToHashSet();
    }

    private async Task BulkViewSelected()
    {
        var ids = string.Join(",", selectedDeliverables.OrderBy(id => id));
        await JS.InvokeVoidAsync("open", $"http://localhost:5115/api/deliverables/bulk-view?ids={ids}", "_blank");
    }

    private async Task BulkDownloadSelected()
    {
        var ids = string.Join(",", selectedDeliverables.OrderBy(id => id));
        await JS.InvokeVoidAsync("open", $"http://localhost:5115/api/deliverables/bulk-download?ids={ids}", "_blank");
    }

    private async Task PreviewFile(int id)
    {
        await JS.InvokeVoidAsync("open", $"http://localhost:5115/api/deliverables/view/{id}", "_blank");
    }

    private async Task OpenDeleteModal(int deliverableId)
    {
        isBulkDelete = false;
        deliverableToDeleteId = deliverableId;
        await JS.InvokeVoidAsync("bootstrapModal.show", "deleteModal");
    }

    private async Task OpenBulkDeleteModal()
    {
        isBulkDelete = true;
        await JS.InvokeVoidAsync("bootstrapModal.show", "deleteModal");
    }

    private async Task ConfirmDelete()
    {
        if (isBulkDelete)
        {
            var deleteTasks = selectedDeliverables.Select(id => Http.DeleteAsync($"api/deliverables/{id}"));
            await Task.WhenAll(deleteTasks);
            selectedDeliverables.Clear();
        }
        else
        {
            await Http.DeleteAsync($"api/deliverables/{deliverableToDeleteId}");
        }

        await ReloadDeliverables();
        await JS.InvokeVoidAsync("bootstrapModal.hide", "deleteModal");
    }

    private async Task AnalyzeSingle(int id) => await RunBulkAnalysis(new[] { id });

    private async Task AnalyzeSelected()
    {
        if (!selectedDeliverables.Any()) return;
        await RunBulkAnalysis(selectedDeliverables.OrderBy(id => id));
    }

    private async Task RunBulkAnalysis(IEnumerable<int> ids)
    {
        isAnalyzingSelected = true;
        bulkReviewItems.Clear();
        bulkReviewIndex = 0;
        analysisError = string.Empty;

        foreach (var id in ids)
        {
            if (analyzingDeliverableIds.Contains(id)) continue;

            analyzingDeliverableIds.Add(id);
            var row = deliverables?.FirstOrDefault(d => d.Id == id);
            var fileName = row?.FileName ?? $"file-{id}.pdf";

            try
            {
                var analysis = await AnalyzeDeliverableCore(id, fileName);
                if (analysis != null)
                {
                    bulkReviewItems.Add(new BulkDeliverableReviewItem
                    {
                        DeliverableId = id,
                        FileName = fileName,
                        ProjectName = analysis.ProjectName,
                        Client = analysis.Client,
                        Tasks = analysis.Tasks
                    });
                }
            }
            catch (Exception ex)
            {
                analysisError = ex.Message;
            }
            finally
            {
                analyzingDeliverableIds.Remove(id);
            }
        }

        isAnalyzingSelected = false;

        if (!bulkReviewItems.Any())
        {
            if (string.IsNullOrEmpty(analysisError))
                analysisError = "AI analysis failed for the selected file(s).";
            return;
        }

        bulkReviewIndex = 0;
        LoadCurrentReviewItem();
        showAnalysisModal = true;
    }

    private async Task<ExtractTasksResponseLocal?> AnalyzeDeliverableCore(int id, string fileName)
    {
        var fileResp = await Http.GetAsync($"api/deliverables/download/{id}");
        if (!fileResp.IsSuccessStatusCode)
        {
            analysisError = "Unable to retrieve the file for analysis.";
            return null;
        }

        var stream = await fileResp.Content.ReadAsStreamAsync();
        var content = new MultipartFormDataContent();
        var streamContent = new StreamContent(stream);
        streamContent.Headers.ContentType = fileResp.Content.Headers.ContentType
            ?? new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
        content.Add(streamContent, "file", fileName);

        var aiUpload = await Http.PostAsync("api/ai/upload", content);
        if (!aiUpload.IsSuccessStatusCode)
        {
            analysisError = "File extraction failed.";
            return null;
        }

        var uploadResp = await aiUpload.Content.ReadFromJsonAsync<AiUploadResp>();
        if (uploadResp == null)
        {
            analysisError = "Invalid extraction response.";
            return null;
        }

        var extractResp = await Http.PostAsJsonAsync("api/ai/extract-tasks", new { Text = uploadResp.FullText });
        if (!extractResp.IsSuccessStatusCode)
        {
            analysisError = "AI analysis failed.";
            return null;
        }

        return await extractResp.Content.ReadFromJsonAsync<ExtractTasksResponseLocal>();
    }

    private void LoadCurrentReviewItem()
    {
        var current = bulkReviewItems.ElementAtOrDefault(bulkReviewIndex);
        if (current == null)
        {
            editableTasks = null;
            return;
        }

        editableCategoryName = CategoryConstants.ResolveName(current.ProjectName);
        editableClient = current.Client ?? string.Empty;
        editableTasks = current.Tasks
            .Select(t => new EditableTask
            {
                Title = t.Title,
                Deadline = DeadlineHelper.ParseDeadline(t.Deadline)
            })
            .ToList();
        analysisError = string.Empty;
    }

    private void AddEditableTask()
    {
        editableTasks?.Add(new EditableTask { Title = string.Empty, Deadline = DeadlineHelper.DefaultDeadline });
    }

    private void RemoveEditableTask(int index)
    {
        if (editableTasks != null && index >= 0 && index < editableTasks.Count)
            editableTasks.RemoveAt(index);
    }

    private async Task CreateTasksFromAnalysisEditable()
    {
        var current = bulkReviewItems.ElementAtOrDefault(bulkReviewIndex);
        if (current == null || editableTasks == null || editableTasks.Count == 0)
            return;

        isCreatingTasks = true;
        analysisError = string.Empty;

        try
        {
            var payload = new AddTasksPayload
            {
                CategoryName = editableCategoryName,
                Client = editableClient ?? string.Empty,
                Status = "Open",
                Tasks = editableTasks.Select(t => new CreateTaskItem
                {
                    Title = t.Title,
                    Deadline = t.Deadline
                }).ToList()
            };

            var resp = await Http.PostAsJsonAsync($"api/deliverables/{current.DeliverableId}/add-tasks", payload);
            if (!resp.IsSuccessStatusCode)
            {
                analysisError = "Failed to create tasks.";
                return;
            }

            if (HasNextReviewItem)
            {
                bulkReviewIndex++;
                LoadCurrentReviewItem();
            }
            else
            {
                showAnalysisModal = false;
                bulkReviewItems.Clear();
                bulkReviewIndex = 0;
                editableTasks = null;
                await ReloadDeliverables();
            }
        }
        catch (Exception ex)
        {
            analysisError = ex.Message;
        }
        finally
        {
            isCreatingTasks = false;
        }
    }

    private void SkipCurrentReview()
    {
        if (HasNextReviewItem)
        {
            bulkReviewIndex++;
            LoadCurrentReviewItem();
        }
        else
        {
            CancelAnalysisReview();
        }
    }

    private void CancelAnalysisReview()
    {
        showAnalysisModal = false;
        bulkReviewItems.Clear();
        bulkReviewIndex = 0;
        editableTasks = null;
        analysisError = string.Empty;
    }

    private class EditableTask
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; } = DeadlineHelper.DefaultDeadline;
    }

    private class BulkDeliverableReviewItem
    {
        public int DeliverableId { get; set; }
        public string FileName { get; set; } = string.Empty;
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public List<ExtractedLocalTask> Tasks { get; set; } = new();
    }

    private class DeliverableRow
    {
        public int Id { get; set; }
        public string FileName { get; set; } = "";
        public string CategoryName { get; set; } = "";
        public DateTime UploadDate { get; set; }
        public int TaskCount { get; set; }
    }

    private class AiUploadResp
    {
        public string FileName { get; set; } = string.Empty;
        public string StoredFileName { get; set; } = string.Empty;
        public string FullText { get; set; } = string.Empty;
    }

    private class ExtractTasksResponseLocal
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public List<ExtractedLocalTask> Tasks { get; set; } = new();
    }

    private class ExtractedLocalTask
    {
        public string Title { get; set; } = string.Empty;
        public string Deadline { get; set; } = string.Empty;
    }

    private class AddTasksPayload
    {
        public string CategoryName { get; set; } = string.Empty;
        public string Client { get; set; } = string.Empty;
        public string Status { get; set; } = "Open";
        public List<CreateTaskItem> Tasks { get; set; } = new();
    }

    private class CreateTaskItem
    {
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; }
    }
}
