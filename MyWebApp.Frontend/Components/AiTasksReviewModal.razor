@using MyWebApp.Frontend.Constants
@using MyWebApp.Frontend.Helpers

@if (Visible && Analysis != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content app-modal border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    @if (BulkProgress != null)
                    {
                        <span class="badge bg-secondary ms-2">@BulkProgress</span>
                    }
                    <button type="button" class="btn-close" @onclick="HandleCancel" disabled="@IsBusy"></button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger">@ErrorMessage</div>
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Category</label>
                            <select class="form-select" @bind="editableCategoryName" disabled="@IsBusy">
                                @foreach (var cat in CategoryConstants.FixedCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Client</label>
                            <input class="form-control" @bind="editableClient" disabled="@IsBusy" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select class="form-select" @bind="editableStatus" disabled="@IsBusy">
                                <option value="OnTrack">OnTrack</option>
                                <option value="AtRisk">AtRisk</option>
                                <option value="Delayed">Delayed</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <span class="badge @GetStatusBadgeClass(editableStatus)">@editableStatus</span>
                        @if (!string.IsNullOrWhiteSpace(editableCategory))
                        {
                            <span class="badge bg-secondary ms-2">@editableCategory</span>
                        }
                    </div>

                    <div class="mb-3">
                        <strong>Summary</strong>
                        <p class="mb-0">@editableSummary</p>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddTask" disabled="@IsBusy">
                            + Add task
                        </button>
                        <span class="text-muted small">Edit or remove tasks before confirming.</span>
                    </div>

                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Deadline</th>
                                <th style="width: 100px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < editableTasks.Count; i++)
                            {
                                var taskIndex = i;
                                <tr>
                                    <td>
                                        <input class="form-control" @bind="editableTasks[taskIndex].Title" disabled="@IsBusy" />
                                    </td>
                                    <td>
                                        <input type="date" class="form-control"
                                               @bind-value="editableTasks[taskIndex].Deadline"
                                               @bind-value:format="yyyy-MM-dd"
                                               disabled="@IsBusy" />
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                @onclick="() => RemoveTask(taskIndex)" disabled="@IsBusy">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HandleCancel" disabled="@IsBusy">
                        Cancel
                    </button>
                    @if (ShowSkipButton)
                    {
                        <button type="button" class="btn btn-outline-secondary" @onclick="HandleSkip" disabled="@IsBusy">
                            Skip
                        </button>
                    }
                    <button type="button" class="btn btn-success" @onclick="SubmitConfirm"
                            disabled="@(IsBusy || !editableTasks.Any())">
                        @if (IsBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Create tasks
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "AI Analysis Review";
    [Parameter] public PmoAnalysisPreview? Analysis { get; set; }
    [Parameter] public string? BulkProgress { get; set; }
    [Parameter] public bool ShowSkipButton { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSkip { get; set; }
    [Parameter] public EventCallback<AiTasksConfirmPayload> OnConfirm { get; set; }

    private string editableCategoryName = CategoryConstants.DefaultCategory;
    private string editableClient = string.Empty;
    private string editableStatus = "OnTrack";
    private string editableCategory = string.Empty;
    private string editableSummary = string.Empty;
    private List<PmoAnalysisTaskRow> editableTasks = new();

    protected override void OnParametersSet()
    {
        if (Analysis == null)
            return;

        var suggested = !string.IsNullOrWhiteSpace(Analysis.CategoryName)
            ? Analysis.CategoryName
            : Analysis.ProjectName;

        editableCategoryName = CategoryConstants.ResolveName(suggested);
        editableClient = Analysis.Client;
        editableStatus = Analysis.Status;
        editableCategory = Analysis.Category;
        editableSummary = Analysis.Summary;
        editableTasks = Analysis.Tasks.Select(t => new PmoAnalysisTaskRow
        {
            Title = t.Title,
            Deadline = DeadlineHelper.Normalize(t.Deadline)
        }).ToList();
    }

    private void AddTask()
    {
        editableTasks.Add(new PmoAnalysisTaskRow
        {
            Title = string.Empty,
            Deadline = DeadlineHelper.DefaultDeadline
        });
    }

    private void RemoveTask(int index)
    {
        if (index >= 0 && index < editableTasks.Count)
            editableTasks.RemoveAt(index);
    }

    private async Task SubmitConfirm()
    {
        if (!editableTasks.Any())
            return;

        var payload = new AiTasksConfirmPayload
        {
            CategoryName = editableCategoryName,
            Client = editableClient,
            Status = editableStatus,
            Category = editableCategory,
            Summary = editableSummary,
            Tasks = editableTasks.ToList()
        };

        await OnConfirm.InvokeAsync(payload);
    }

    private async Task HandleCancel() => await OnCancel.InvokeAsync();

    private async Task HandleSkip() => await OnSkip.InvokeAsync();

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "AtRisk" => "bg-warning text-dark",
        "Delayed" => "bg-danger",
        _ => "bg-success"
    };
}
