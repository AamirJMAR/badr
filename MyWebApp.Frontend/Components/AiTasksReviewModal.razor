@inject HttpClient Http

@if (Visible && Analysis != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    @if (BulkProgress != null)
                    {
                        <span class="badge bg-secondary ms-2">@BulkProgress</span>
                    }
                    <button type="button" class="btn-close" @onclick="HandleCancel" disabled="@IsBusy"></button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger">@ErrorMessage</div>
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Projet</label>
                            <input class="form-control" @bind="editableProjectName" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Client</label>
                            <input class="form-control" @bind="editableClient" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Statut</label>
                            <select class="form-select" @bind="editableStatus">
                                <option value="OnTrack">OnTrack</option>
                                <option value="AtRisk">AtRisk</option>
                                <option value="Delayed">Delayed</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <span class="badge @GetStatusBadgeClass(editableStatus)">@editableStatus</span>
                        <span class="badge bg-secondary ms-2">@editableCategory</span>
                    </div>

                    <div class="mb-3">
                        <strong>Résumé</strong>
                        <p class="mb-0">@editableSummary</p>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddTask" disabled="@IsBusy">
                            + Ajouter une tâche
                        </button>
                        <span class="text-muted small">Modifiez ou supprimez les tâches avant validation.</span>
                    </div>

                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Tâche</th>
                                <th>Échéance</th>
                                <th style="width: 100px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i <editableTasks.Count; i++)
                            {
                                var taskIndex = i;
                                <tr>
                                    <td>
                                        <input class="form-control" @bind="editableTasks[taskIndex].Title" disabled="@IsBusy" />
                                    </td>
                                    <td>
                                        <input class="form-control" @bind="editableTasks[taskIndex].Deadline"
                                               placeholder="yyyy-MM-dd ou TBD" disabled="@IsBusy" />
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                @onclick="() => RemoveTask(taskIndex)" disabled="@IsBusy">
                                            Supprimer
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (showProjectConfirm)
                    {
                        <div class="alert alert-warning mt-3">
                            <strong>Projet déjà existant</strong>
                            <p class="mb-2">
                                Le projet <strong>@editableProjectName</strong> existe déjà.
                                Voulez-vous ajouter ces tâches à ce projet ?
                            </p>
                            <button class="btn btn-success btn-sm me-2" @onclick="ConfirmWithExistingProject" disabled="@IsBusy">
                                Confirmer
                            </button>
                            <button class="btn btn-secondary btn-sm" @onclick="() => showProjectConfirm = false" disabled="@IsBusy">
                                Retour
                            </button>
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HandleCancel" disabled="@IsBusy">
                        Annuler
                    </button>
                    @if (ShowSkipButton)
                    {
                        <button type="button" class="btn btn-outline-secondary" @onclick="HandleSkip" disabled="@IsBusy">
                            Passer
                        </button>
                    }
                    <button type="button" class="btn btn-success" @onclick="HandleValidateClick"
                            disabled="@(IsBusy || !editableTasks.Any() || showProjectConfirm)">
                        @if (IsBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Valider et créer les tâches
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Revue analyse IA";
    [Parameter] public PmoAnalysisPreview? Analysis { get; set; }
    [Parameter] public string CheckProjectApiUrl { get; set; } = "api/emaillogs/check-project";
    [Parameter] public string? BulkProgress { get; set; }
    [Parameter] public bool ShowSkipButton { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSkip { get; set; }
    [Parameter] public EventCallback<AiTasksConfirmPayload> OnConfirm { get; set; }

    private string editableProjectName = string.Empty;
    private string editableClient = string.Empty;
    private string editableStatus = "OnTrack";
    private string editableCategory = string.Empty;
    private string editableSummary = string.Empty;
    private List<PmoAnalysisTaskRow> editableTasks = new();
    private bool showProjectConfirm;

    protected override void OnParametersSet()
    {
        if (Analysis == null)
            return;

        editableProjectName = Analysis.ProjectName;
        editableClient = Analysis.Client;
        editableStatus = Analysis.Status;
        editableCategory = Analysis.Category;
        editableSummary = Analysis.Summary;
        editableTasks = Analysis.Tasks.Select(t => new PmoAnalysisTaskRow
        {
            Title = t.Title,
            Deadline = t.Deadline
        }).ToList();
        showProjectConfirm = false;
    }

    private void AddTask()
    {
        editableTasks.Add(new PmoAnalysisTaskRow { Title = string.Empty, Deadline = "TBD" });
    }

    private void RemoveTask(int index)
    {
        if (index >= 0 && index < editableTasks.Count)
            editableTasks.RemoveAt(index);
    }

    private async Task HandleValidateClick()
    {
        if (!editableTasks.Any())
            return;

        var projectName = string.IsNullOrWhiteSpace(editableProjectName) ? Title : editableProjectName;

        try
        {
            var response = await Http.PostAsJsonAsync(CheckProjectApiUrl, projectName);
            var result = await response.Content.ReadFromJsonAsync<ProjectCheckResult>();

            if (result?.Exists == true)
            {
                showProjectConfirm = true;
                return;
            }
        }
        catch
        {
            // Si la vérification échoue, on laisse l'utilisateur valider quand même
        }

        await SubmitConfirm();
    }

    private async Task ConfirmWithExistingProject() => await SubmitConfirm();

    private async Task SubmitConfirm()
    {
        showProjectConfirm = false;

        var payload = new AiTasksConfirmPayload
        {
            ProjectName = string.IsNullOrWhiteSpace(editableProjectName) ? Title : editableProjectName,
            Client = editableClient,
            Status = editableStatus,
            Category = editableCategory,
            Summary = editableSummary,
            Tasks = editableTasks.ToList()
        };

        await OnConfirm.InvokeAsync(payload);
    }

    private async Task HandleCancel() => await OnCancel.InvokeAsync();

    private async Task HandleSkip() => await OnSkip.InvokeAsync();

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "AtRisk" => "bg-warning text-dark",
        "Delayed" => "bg-danger",
        _ => "bg-success"
    };

    private class ProjectCheckResult
    {
        public bool Exists { get; set; }
    }
}
